<Window x:Class="BreakersOfE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Breakers of E"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- ── Base button style ── -->
        <Style TargetType="Button" x:Key="MenuButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid column header style ── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <!-- ── DataGrid row style ── -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{Binding RowForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid cell style ── -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Label style for detail panel ── -->
        <Style TargetType="TextBlock" x:Key="DetailLabel">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,6,0,1"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="DetailValue">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ── ComboBox dark style ── -->
        <Style TargetType="ComboBox" x:Key="DarkComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="28"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Menu bar -->
            <RowDefinition Height="25"/>
            <!-- Toolbar / mode switcher -->
            <RowDefinition Height="40"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 0 — MENU BAR
        ══════════════════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0"
              Background="#2D2D30"
              Foreground="White"
              FontSize="13">

            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2D2D30"/>
                </Style>
            </Menu.Resources>

            <!-- File -->
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>

            <!-- View -->
            <MenuItem Header="_View">
                <MenuItem Header="_Pool"           Click="MenuViewPool_Click"/>
                <MenuItem Header="_Collection"     Click="MenuViewCollection_Click"/>
                <MenuItem Header="_Trade Binder"   Click="MenuViewTradeBinder_Click"/>
                <Separator/>
                <MenuItem Header="To_kens"         Click="MenuViewTokens_Click"/>
                <MenuItem Header="My _Tokens"      Click="MenuViewMyTokens_Click"/>
                <Separator/>
                <MenuItem Header="P_lanar Cards"   Click="MenuViewPlanar_Click"/>
                <MenuItem Header="My Planar Cards" Click="MenuViewMyPlanar_Click"/>
                <Separator/>
                <MenuItem Header="_Schemes"        Click="MenuViewSchemes_Click"/>
                <MenuItem Header="My Schemes"      Click="MenuViewMySchemes_Click"/>
                <Separator/>
                <MenuItem Header="_Vanguard"       Click="MenuViewVanguard_Click"/>
                <Separator/>
                <MenuItem Header="Conspirac_y"     Click="MenuViewConspiracy_Click"/>
                <Separator/>
                <MenuItem Header="_Art Series"     Click="MenuViewArtSeries_Click"/>
                <MenuItem Header="My Art Series"   Click="MenuViewMyArtSeries_Click"/>
                <Separator/>
                <MenuItem Header="_Dashboard"      Click="MenuViewDashboard_Click"/>
            </MenuItem>

            <!-- Tools -->
            <MenuItem Header="_Tools">
                <MenuItem Header="_Update Card Database" Click="MenuUpdateDatabase_Click"/>
                <Separator/>
                <MenuItem Header="_Settings"             Click="MenuSettings_Click"/>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="MenuAbout_Click"/>
            </MenuItem>

        </Menu>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 1 — TOOLBAR / MODE SWITCHER
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#252526" BorderBrush="#3F3F46"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">

                <!-- App title -->
                <TextBlock Text="Breakers of E"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"
                           DockPanel.Dock="Left"/>

                <!-- Mode label + dropdown on the RIGHT -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right">
                    <TextBlock Text="View Mode:"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox Name="ViewModeComboBox"
                              Style="{StaticResource DarkComboBox}"
                              Width="220"
                              SelectionChanged="ViewModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Pool"             Tag="Pool"/>
                        <ComboBoxItem Content="Collection"       Tag="Collection"/>
                        <ComboBoxItem Content="Trade Binder"     Tag="TradeBinder"/>
                        <ComboBoxItem Content="── Tokens ──"     IsEnabled="False"/>
                        <ComboBoxItem Content="Token Database"   Tag="Tokens"/>
                        <ComboBoxItem Content="My Tokens"        Tag="MyTokens"/>
                        <ComboBoxItem Content="── Planar ──"     IsEnabled="False"/>
                        <ComboBoxItem Content="Planar Database"  Tag="Planar"/>
                        <ComboBoxItem Content="My Planar Cards"  Tag="MyPlanar"/>
                        <ComboBoxItem Content="── Schemes ──"    IsEnabled="False"/>
                        <ComboBoxItem Content="Scheme Database"  Tag="Schemes"/>
                        <ComboBoxItem Content="My Schemes"       Tag="MySchemes"/>
                        <ComboBoxItem Content="── Other ──"      IsEnabled="False"/>
                        <ComboBoxItem Content="Vanguard"         Tag="Vanguard"/>
                        <ComboBoxItem Content="Conspiracy"       Tag="Conspiracy"/>
                        <ComboBoxItem Content="Art Series"       Tag="ArtSeries"/>
                        <ComboBoxItem Content="My Art Series"    Tag="MyArtSeries"/>
                        <ComboBoxItem Content="── ──"            IsEnabled="False"/>
                        <ComboBoxItem Content="Dashboard"        Tag="Dashboard"/>
                    </ComboBox>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 2 — MAIN CONTENT
        ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- Left: card image + details -->
                <ColumnDefinition Width="260" MinWidth="200"/>
                <!-- Splitter -->
                <ColumnDefinition Width="4"/>
                <!-- Right: data grid -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ─────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#1E1E1E"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <!-- Card image -->
                        <Border Name="CardImageBorder"
                                Width="223" Height="310"
                                Background="#2D2D30"
                                BorderBrush="#555555"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,6,0,10"
                                HorizontalAlignment="Center">
                            <Image Name="CardImage" Stretch="Uniform"/>
                        </Border>

                        <!-- Card name -->
                        <TextBlock Text="NAME" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailName"
                                   Style="{StaticResource DetailValue}"
                                   FontSize="14"
                                   FontWeight="Bold"/>

                        <!-- Mana cost (symbols rendered here) -->
                        <TextBlock Text="MANA COST" Style="{StaticResource DetailLabel}"/>
                        <WrapPanel Name="DetailManaCostPanel" Margin="0,2,0,0"/>

                        <!-- Type -->
                        <TextBlock Text="TYPE" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailType" Style="{StaticResource DetailValue}"/>

                        <!-- Set + set symbol -->
                        <TextBlock Text="SET" Style="{StaticResource DetailLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Image Name="DetailSetSymbol"
                                   Width="16" Height="16"
                                   Margin="0,0,5,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Name="DetailSet"
                                       Style="{StaticResource DetailValue}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Collector number -->
                        <TextBlock Text="COLLECTOR NUMBER" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailCollectorNumber"
                                   Style="{StaticResource DetailValue}"/>

                        <!-- Rarity -->
                        <TextBlock Text="RARITY" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailRarity" Style="{StaticResource DetailValue}"/>

                        <!-- P/T or Loyalty -->
                        <TextBlock Name="DetailPTLabel"
                                   Text="POWER / TOUGHNESS"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailPT" Style="{StaticResource DetailValue}"/>

                        <!-- Oracle text -->
                        <TextBlock Text="ORACLE TEXT" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailOracle"
                                   Style="{StaticResource DetailValue}"
                                   FontSize="11"/>

                        <!-- Flavor text -->
                        <TextBlock Text="FLAVOR TEXT" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailFlavor"
                                   Style="{StaticResource DetailValue}"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   Foreground="#AAAAAA"/>

                        <!-- Artist -->
                        <TextBlock Text="ARTIST" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailArtist" Style="{StaticResource DetailValue}"/>

                        <!-- Foil / Non-Foil -->
                        <TextBlock Text="AVAILABLE AS" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailFoilNonFoil"
                                   Style="{StaticResource DetailValue}"/>

                        <!-- Prices -->
                        <TextBlock Text="PRICES (USD)" Style="{StaticResource DetailLabel}"/>
                        <TextBlock Name="DetailPrices"
                                   Style="{StaticResource DetailValue}"
                                   FontSize="11"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── SPLITTER ───────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="#3F3F46"
                          Cursor="SizeWE"/>

            <!-- ── RIGHT PANEL ────────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!-- Search / filter bar -->
                    <RowDefinition Height="40"/>
                    <!-- Data grid -->
                    <RowDefinition Height="*"/>
                    <!-- Row count bar -->
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0"
                        Background="#252526"
                        BorderBrush="#3F3F46"
                        BorderThickness="0,0,0,1"
                        Padding="8,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍"
                                   Foreground="#AAAAAA"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBox Name="SearchBox"
                                 Width="280"
                                 Height="26"
                                 Background="#3C3C3C"
                                 Foreground="White"
                                 BorderBrush="#555555"
                                 CaretBrush="White"
                                 Padding="6,4"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock Text="Search by name, set, type..."
                                   Foreground="#666666"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Name="SearchPlaceholder"/>
                    </StackPanel>
                </Border>

                <!-- Main DataGrid -->
                <DataGrid Name="MainDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          SelectionChanged="MainDataGrid_SelectionChanged"
                          Background="#1E1E1E"
                          Foreground="White"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2D2D30"
                          RowHeaderWidth="0"
                          CanUserResizeRows="False"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">

                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                         Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                         Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                         Color="White"/>
                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <!-- Favorite star -->
                        <DataGridTemplateColumn Header="★" Width="28" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FavoriteGlyph}"
                                               HorizontalAlignment="Center"
                                               Foreground="Gold"
                                               FontSize="12"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Set symbol (ES) -->
                        <DataGridTemplateColumn Header="ES" Width="32" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding SetSymbolPath}"
                                           Width="16" Height="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Name -->
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="200"/>

                        <!-- Edition (set code) -->
                        <DataGridTextColumn Header="Edition"
                                            Binding="{Binding SetCode}"
                                            Width="60"/>

                        <!-- Edition Name -->
                        <DataGridTextColumn Header="Edition Name"
                                            Binding="{Binding SetName}"
                                            Width="160"/>

                        <!-- Color -->
                        <DataGridTextColumn Header="Color"
                                            Binding="{Binding ColorIdentity}"
                                            Width="60"/>

                        <!-- Type -->
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding TypeLine}"
                                            Width="180"/>

                        <!-- Rarity -->
                        <DataGridTextColumn Header="Rarity"
                                            Binding="{Binding RarityCode}"
                                            Width="50"/>

                        <!-- Mana Cost (text fallback — symbols come later) -->
                        <DataGridTextColumn Header="Cost"
                                            Binding="{Binding ManaCost}"
                                            Width="90"/>

                        <!-- P/T -->
                        <DataGridTextColumn Header="P/T"
                                            Binding="{Binding PowerToughness}"
                                            Width="60"/>

                        <!-- Oracle Text -->
                        <DataGridTextColumn Header="Text"
                                            Binding="{Binding OracleText}"
                                            Width="220"/>

                        <!-- Flavor -->
                        <DataGridTextColumn Header="Flavor"
                                            Binding="{Binding FlavorText}"
                                            Width="180"/>

                        <!-- Artist -->
                        <DataGridTextColumn Header="Artist"
                                            Binding="{Binding Artist}"
                                            Width="130"/>

                        <!-- Collector No -->
                        <DataGridTextColumn Header="No"
                                            Binding="{Binding CollectorNumber}"
                                            Width="55"/>

                        <!-- Power -->
                        <DataGridTextColumn Header="Power"
                                            Binding="{Binding Power}"
                                            Width="50"/>

                        <!-- Toughness -->
                        <DataGridTextColumn Header="Toughness"
                                            Binding="{Binding Toughness}"
                                            Width="70"/>

                        <!-- CMC / Mana Value -->
                        <DataGridTextColumn Header="CMC"
                                            Binding="{Binding ManaValue}"
                                            Width="45"/>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Row count bar -->
                <Border Grid.Row="2"
                        Background="#007ACC"
                        Padding="8,3">
                    <TextBlock Name="RowCountText"
                               Foreground="White"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Border>

            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 3 — STATUS BAR
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#007ACC">
            <TextBlock Name="StatusText"
                       Foreground="White"
                       FontSize="12"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
