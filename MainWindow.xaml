<Window x:Class="BreakersOfE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Breakers of E"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ── DataGrid column header style ── -->
        <Style x:Key="DataGridColumnHeaderStyle"
               TargetType="DataGridColumnHeader">
            <Setter Property="Background"
                    Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ── DataGrid row style — binds to card color brushes ── -->
        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background"
                    Value="{Binding RowBackgroundBrush}"/>
            <Setter Property="Foreground"
                    Value="{Binding RowForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid cell style — full border, theme-aware ── -->
        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="{Binding CellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground"
                            Value="{Binding RowForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 0 — MENU BAR
        ══════════════════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0"
              Background="{DynamicResource SurfaceAltBrush}"
              Foreground="{DynamicResource PrimaryTextBrush}"
              FontSize="13">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground"
                            Value="{DynamicResource PrimaryTextBrush}"/>
                    <Setter Property="Background"
                            Value="{DynamicResource SurfaceAltBrush}"/>
                </Style>
            </Menu.Resources>

            <MenuItem Header="_File">
                <MenuItem Header="_Preferences"
                          Click="MenuPreferences_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="_Theme">
                    <MenuItem Header="_Light Mode"
                              Click="MenuThemeLight_Click"/>
                    <MenuItem Header="_Dark Mode"
                              Click="MenuThemeDark_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Pool"
                          Click="MenuViewPool_Click"/>
                <MenuItem Header="_Collection"
                          Click="MenuViewCollection_Click"/>
                <MenuItem Header="_Trade Binder"
                          Click="MenuViewTradeBinder_Click"/>
                <Separator/>
                <MenuItem Header="To_kens"
                          Click="MenuViewTokens_Click"/>
                <MenuItem Header="My _Tokens"
                          Click="MenuViewMyTokens_Click"/>
                <Separator/>
                <MenuItem Header="P_lanar Cards"
                          Click="MenuViewPlanar_Click"/>
                <MenuItem Header="My Planar _Cards"
                          Click="MenuViewMyPlanar_Click"/>
                <Separator/>
                <MenuItem Header="_Schemes"
                          Click="MenuViewSchemes_Click"/>
                <MenuItem Header="My _Schemes"
                          Click="MenuViewMySchemes_Click"/>
                <Separator/>
                <MenuItem Header="_Vanguard"
                          Click="MenuViewVanguard_Click"/>
                <Separator/>
                <MenuItem Header="Conspirac_y"
                          Click="MenuViewConspiracy_Click"/>
                <Separator/>
                <MenuItem Header="_Art Series"
                          Click="MenuViewArtSeries_Click"/>
                <MenuItem Header="My Art _Series"
                          Click="MenuViewMyArtSeries_Click"/>
                <Separator/>
                <MenuItem Header="_Dashboard"
                          Click="MenuViewDashboard_Click"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="_Update Card Database"
                          Click="MenuUpdateDatabase_Click"/>
                <Separator/>
                <MenuItem Header="_Settings"
                          Click="MenuSettings_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 1 — TOOLBAR
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0" LastChildFill="False">

                <Button Name="BtnUpdateDb"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE117;"
                        ToolTip="Update Card Database"
                        Click="BtnUpdateDb_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}"
                           DockPanel.Dock="Left"/>

                <Button Name="BtnAdd1"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE109;"
                        ToolTip="Add 1 Copy"
                        IsEnabled="False"
                        Click="BtnAdd1_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Button Name="BtnAddFoil"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE1D9;"
                        ToolTip="Add 1 Foil Copy"
                        IsEnabled="False"
                        Click="BtnAddFoil_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <TextBox Name="TxtQty"
                         Width="46" Height="28"
                         Style="{DynamicResource BaseTextBoxStyle}"
                         Text="1"
                         VerticalContentAlignment="Center"
                         TextAlignment="Center"
                         IsEnabled="False"
                         DockPanel.Dock="Left" Margin="2,8"/>

                <Button Name="BtnAddQty"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE1FE;"
                        ToolTip="Add Quantity"
                        IsEnabled="False"
                        Click="BtnAddQty_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Button Name="BtnRemove1"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE108;"
                        ToolTip="Remove 1 Copy"
                        IsEnabled="False"
                        Click="BtnRemove1_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}"
                           DockPanel.Dock="Left"/>

                <Button Name="BtnQtyPlus"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE1E8;"
                        ToolTip="Increase Quantity"
                        IsEnabled="False"
                        Visibility="Collapsed"
                        Click="BtnQtyPlus_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Button Name="BtnQtyMinus"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE1E9;"
                        ToolTip="Decrease Quantity"
                        IsEnabled="False"
                        Visibility="Collapsed"
                        Click="BtnQtyMinus_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Separator Name="SepQty"
                           Style="{DynamicResource ToolbarSeparatorStyle}"
                           Visibility="Collapsed"
                           DockPanel.Dock="Left"/>

                <Button Name="BtnFilterTop"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE16E;"
                        ToolTip="Filter Top Table"
                        Click="BtnFilterTop_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Button Name="BtnLegality"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE1C6;"
                        ToolTip="Toggle Legality Columns"
                        Click="BtnLegality_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}"
                           DockPanel.Dock="Left"/>

                <Button Name="BtnTheme"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Content="&#xE706;"
                        ToolTip="Toggle Light/Dark Mode"
                        Click="BtnTheme_Click"
                        DockPanel.Dock="Left" Margin="2,4"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <TextBlock Text="Mode:"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <ComboBox Name="ViewModeComboBox"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Width="220"
                              SelectionChanged="ViewModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="── Browse ──"
                                      IsEnabled="False"
                                      FontWeight="Bold"/>
                        <ComboBoxItem Content="Pool"            Tag="Pool"/>
                        <ComboBoxItem Content="Collection"      Tag="Collection"/>
                        <ComboBoxItem Content="Trade Binder"    Tag="TradeBinder"/>
                        <ComboBoxItem Content="Token Database"  Tag="Tokens"/>
                        <ComboBoxItem Content="My Tokens"       Tag="MyTokens"/>
                        <ComboBoxItem Content="Planar Database" Tag="Planar"/>
                        <ComboBoxItem Content="My Planar Cards" Tag="MyPlanar"/>
                        <ComboBoxItem Content="Scheme Database" Tag="Schemes"/>
                        <ComboBoxItem Content="My Schemes"      Tag="MySchemes"/>
                        <ComboBoxItem Content="Vanguard"        Tag="Vanguard"/>
                        <ComboBoxItem Content="Conspiracy"      Tag="Conspiracy"/>
                        <ComboBoxItem Content="Art Series"      Tag="ArtSeries"/>
                        <ComboBoxItem Content="My Art Series"   Tag="MyArtSeries"/>
                        <ComboBoxItem Content="── Work ──"
                                      IsEnabled="False"
                                      FontWeight="Bold"/>
                        <ComboBoxItem Content="Pool → Collection"
                                      Tag="PoolToCollection"/>
                        <ComboBoxItem Content="Pool → Deck"
                                      Tag="PoolToDeck"/>
                        <ComboBoxItem Content="Collection → Deck"
                                      Tag="CollectionToDeck"/>
                        <ComboBoxItem Content="── Other ──"
                                      IsEnabled="False"
                                      FontWeight="Bold"/>
                        <ComboBoxItem Content="Dashboard"       Tag="Dashboard"/>
                    </ComboBox>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 2 — MAIN CONTENT
        ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ──────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <Border Name="CardImageBorder"
                                Width="223" Height="310"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,6,0,10"
                                HorizontalAlignment="Center">
                            <Image Name="CardImage" Stretch="Uniform"/>
                        </Border>

                        <TextBlock Text="NAME"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailName"
                                   Style="{DynamicResource DetailValueStyle}"
                                   FontSize="14" FontWeight="Bold"/>

                        <TextBlock Text="MANA COST"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <WrapPanel Name="DetailManaCostPanel"
                                   Margin="0,2,0,0"/>

                        <TextBlock Text="TYPE"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailType"
                                   Style="{DynamicResource DetailValueStyle}"/>

                        <TextBlock Text="SET"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,2,0,0">
                            <Image Name="DetailSetSymbol"
                                   Width="16" Height="16"
                                   Margin="0,0,5,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Name="DetailSet"
                                       Style="{DynamicResource DetailValueStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="COLLECTOR NUMBER"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailCollectorNumber"
                                   Style="{DynamicResource DetailValueStyle}"/>

                        <TextBlock Text="RARITY"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailRarity"
                                   Style="{DynamicResource DetailValueStyle}"/>

                        <TextBlock Name="DetailPTLabel"
                                   Text="POWER / TOUGHNESS"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailPT"
                                   Style="{DynamicResource DetailValueStyle}"/>

                        <TextBlock Text="ORACLE TEXT"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailOracle"
                                   Style="{DynamicResource DetailValueStyle}"
                                   FontSize="11"/>

                        <TextBlock Text="FLAVOR TEXT"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailFlavor"
                                   Style="{DynamicResource DetailValueStyle}"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource MutedTextBrush}"/>

                        <TextBlock Text="ARTIST"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailArtist"
                                   Style="{DynamicResource DetailValueStyle}"/>

                        <TextBlock Text="AVAILABLE AS"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailFoilNonFoil"
                                   Style="{DynamicResource DetailValueStyle}"/>

                        <TextBlock Text="PRICES (USD)"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailPrices"
                                   Style="{DynamicResource DetailValueStyle}"
                                   FontSize="11"/>

                        <TextBlock Text="FORMAT LEGALITY"
                                   Style="{DynamicResource DetailLabelStyle}"/>
                        <StackPanel Name="DetailLegalityPanel"
                                    Margin="0,2,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── SPLITTER ────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          Cursor="SizeWE"/>

            <!-- ── RIGHT PANEL ────────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="100"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="80"/>
                </Grid.RowDefinitions>

                <!-- ── TOP TABLE ──────────────────────────────────────── -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <!-- Group by bar -->
                    <Border Grid.Row="0"
                            Style="{DynamicResource GroupByBarStyle}">
                        <TextBlock Name="TopGroupByLabel"
                                   Text="Drag a column header here to group by that column"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="6,0"/>
                    </Border>

                    <!-- Search bar -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,4">
                        <DockPanel>
                            <TextBlock Text="&#xE11A;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       DockPanel.Dock="Left"/>
                            <TextBlock Name="TopSearchLabel"
                                       Text="Pool"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"
                                       DockPanel.Dock="Left"/>
                            <TextBox Name="TopSearchBox"
                                     Style="{DynamicResource BaseTextBoxStyle}"
                                     Height="26" Width="280"
                                     VerticalContentAlignment="Center"
                                     DockPanel.Dock="Left"
                                     TextChanged="TopSearchBox_TextChanged"/>
                        </DockPanel>
                    </Border>

                    <!-- Top DataGrid -->
                    <DataGrid Name="TopDataGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              SelectionChanged="TopDataGrid_SelectionChanged"
                              KeyDown="TopDataGrid_KeyDown"
                              Background="{DynamicResource GridRowBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              RowHeaderWidth="0"
                              CanUserResizeRows="True"
                              CanUserReorderColumns="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle}"
                              RowStyle="{DynamicResource DataGridRowStyle}"
                              CellStyle="{DynamicResource DataGridCellStyle}">

                        <DataGrid.Resources>
                            <SolidColorBrush
                                x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                Color="Transparent"/>
                            <SolidColorBrush
                                x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                Color="Transparent"/>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="★" Width="28"
                                                    CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FavoriteGlyph}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="Gold"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ES" Width="32"
                                                    CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding SetSymbolPath}"
                                               Width="16" Height="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Edition"
                                Binding="{Binding SetCode}" Width="60"/>
                            <DataGridTextColumn Header="Edition Name"
                                Binding="{Binding SetName}" Width="160"/>
                            <DataGridTextColumn Header="Color"
                                Binding="{Binding ColorIdentity}" Width="60"/>
                            <DataGridTextColumn Header="Type"
                                Binding="{Binding TypeLine}" Width="180"/>
                            <DataGridTextColumn Header="Rarity"
                                Binding="{Binding RarityCode}" Width="50"/>
                            <DataGridTextColumn Header="Cost"
                                Binding="{Binding ManaCost}" Width="90"/>
                            <DataGridTextColumn Header="P/T"
                                Binding="{Binding PowerToughness}" Width="55"/>
                            <DataGridTextColumn Header="Text"
                                Binding="{Binding OracleText}" Width="220"/>
                            <DataGridTextColumn Header="Flavor"
                                Binding="{Binding FlavorText}" Width="160"/>
                            <DataGridTextColumn Header="Artist"
                                Binding="{Binding Artist}" Width="130"/>
                            <DataGridTextColumn Header="No"
                                Binding="{Binding CollectorNumber}" Width="55"/>
                            <DataGridTextColumn Header="Power"
                                Binding="{Binding Power}" Width="50"/>
                            <DataGridTextColumn Header="Toughness"
                                Binding="{Binding Toughness}" Width="70"/>
                            <DataGridTextColumn Header="CMC"
                                Binding="{Binding ManaValue}" Width="45"/>

                            <!-- Legality columns — hidden by default -->
                            <DataGridTextColumn Header="Standard"
                                Binding="{Binding LegalityStandard}"
                                Width="70" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Pioneer"
                                Binding="{Binding LegalityPioneer}"
                                Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Modern"
                                Binding="{Binding LegalityModern}"
                                Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Legacy"
                                Binding="{Binding LegalityLegacy}"
                                Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Vintage"
                                Binding="{Binding LegalityVintage}"
                                Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Commander"
                                Binding="{Binding LegalityCommander}"
                                Width="80" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Pauper"
                                Binding="{Binding LegalityPauper}"
                                Width="65" Visibility="Collapsed"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Top filter bar -->
                    <Border Grid.Row="3"
                            Style="{DynamicResource FilterBarStyle}">
                        <DockPanel>
                            <Button Name="BtnTopFilterCustomize"
                                    Content="Customize"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="4,0"
                                    Click="BtnTopFilterCustomize_Click"/>
                            <Button Name="BtnTopFilterClear"
                                    Content="Clear"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="0,0,2,0"
                                    Click="BtnTopFilterClear_Click"/>
                            <CheckBox Name="ChkTopFilter"
                                      IsChecked="False"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0"
                                      DockPanel.Dock="Left"
                                      Checked="ChkTopFilter_Changed"
                                      Unchecked="ChkTopFilter_Changed"/>
                            <TextBlock Name="TopFilterSummary"
                                       Text="No filter active"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- ── ACTION BUTTONS BAR ──────────────────────────────── -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,1"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Name="ActionBarLabel"
                                   Text="Select a mode to add cards"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── BOTTOM TABLE ────────────────────────────────────── -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <!-- Group by bar -->
                    <Border Grid.Row="0"
                            Style="{DynamicResource GroupByBarStyle}">
                        <TextBlock Name="BottomGroupByLabel"
                                   Text="Drag a column header here to group by that column"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="6,0"/>
                    </Border>

                    <!-- Search bar -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,4">
                        <DockPanel>
                            <TextBlock Text="&#xE11A;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       DockPanel.Dock="Left"/>
                            <TextBlock Name="BottomSearchLabel"
                                       Text="Collection"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"
                                       DockPanel.Dock="Left"/>
                            <TextBox Name="BottomSearchBox"
                                     Style="{DynamicResource BaseTextBoxStyle}"
                                     Height="26" Width="280"
                                     VerticalContentAlignment="Center"
                                     DockPanel.Dock="Left"
                                     TextChanged="BottomSearchBox_TextChanged"/>
                        </DockPanel>
                    </Border>

                    <!-- Bottom DataGrid -->
                    <DataGrid Name="BottomDataGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              SelectionChanged="BottomDataGrid_SelectionChanged"
                              Background="{DynamicResource GridRowBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              RowHeaderWidth="0"
                              CanUserResizeRows="True"
                              CanUserReorderColumns="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle}"
                              RowStyle="{DynamicResource DataGridRowStyle}"
                              CellStyle="{DynamicResource DataGridCellStyle}">

                        <DataGrid.Resources>
                            <SolidColorBrush
                                x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                Color="Transparent"/>
                            <SolidColorBrush
                                x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                Color="Transparent"/>
                        </DataGrid.Resources>

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove 1 Copy"
                                          Click="CtxRemove1_Click"/>
                                <MenuItem Header="Remove All Copies"
                                          Click="CtxRemoveAll_Click"/>
                                <Separator/>
                                <MenuItem Header="View Card Details"
                                          Click="CtxViewDetails_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="★" Width="28"
                                                    CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FavoriteGlyph}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="Gold"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ES" Width="32"
                                                    CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding SetSymbolPath}"
                                               Width="16" Height="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Edition"
                                Binding="{Binding SetCode}" Width="60"/>
                            <DataGridTextColumn Header="Edition Name"
                                Binding="{Binding SetName}" Width="160"/>

                            <!-- Qty spinner column -->
                            <DataGridTemplateColumn Header="Qty" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="−"
                                                    Width="22" Height="18"
                                                    FontSize="12" Padding="0"
                                                    Tag="{Binding}"
                                                    Click="BtnQtyMinus_Row_Click"/>
                                            <TextBox Width="34" Height="18"
                                                     Text="{Binding Quantity,
                                                         Mode=TwoWay,
                                                         UpdateSourceTrigger=PropertyChanged}"
                                                     TextAlignment="Center"
                                                     FontSize="11" Padding="0"
                                                     BorderThickness="1"
                                                     Tag="{Binding}"
                                                     TextChanged="TxtQtyRow_TextChanged"
                                                     PreviewKeyDown="TxtQtyRow_KeyDown"/>
                                            <Button Content="+"
                                                    Width="22" Height="18"
                                                    FontSize="12" Padding="0"
                                                    Tag="{Binding}"
                                                    Click="BtnQtyPlus_Row_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Foil Qty spinner column -->
                            <DataGridTemplateColumn Header="Foil Qty" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="−"
                                                    Width="22" Height="18"
                                                    FontSize="12" Padding="0"
                                                    Tag="{Binding}"
                                                    Click="BtnFoilQtyMinus_Row_Click"/>
                                            <TextBox Width="34" Height="18"
                                                     Text="{Binding FoilQuantity,
                                                         Mode=TwoWay,
                                                         UpdateSourceTrigger=PropertyChanged}"
                                                     TextAlignment="Center"
                                                     FontSize="11" Padding="0"
                                                     BorderThickness="1"
                                                     Tag="{Binding}"
                                                     TextChanged="TxtFoilQtyRow_TextChanged"
                                                     PreviewKeyDown="TxtFoilQtyRow_KeyDown"/>
                                            <Button Content="+"
                                                    Width="22" Height="18"
                                                    FontSize="12" Padding="0"
                                                    Tag="{Binding}"
                                                    Click="BtnFoilQtyPlus_Row_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Used"
                                Binding="{Binding UsedCount}" Width="50"/>
                            <DataGridTextColumn Header="Available"
                                Binding="{Binding AvailableCount}" Width="70"/>
                            <DataGridTextColumn Header="Color"
                                Binding="{Binding ColorIdentity}" Width="55"/>
                            <DataGridTextColumn Header="Type"
                                Binding="{Binding TypeLine}" Width="160"/>
                            <DataGridTextColumn Header="Rarity"
                                Binding="{Binding RarityCode}" Width="50"/>
                            <DataGridTextColumn Header="Cost"
                                Binding="{Binding ManaCost}" Width="90"/>
                            <DataGridTextColumn Header="P/T"
                                Binding="{Binding PowerToughness}" Width="55"/>
                            <DataGridTextColumn Header="Condition"
                                Binding="{Binding Condition}" Width="80"/>
                            <DataGridTextColumn Header="Language"
                                Binding="{Binding Language}" Width="75"/>
                            <DataGridTextColumn Header="Storage"
                                Binding="{Binding StorageLocation}" Width="100"/>
                            <DataGridTextColumn Header="Artist"
                                Binding="{Binding Artist}" Width="130"/>
                            <DataGridTextColumn Header="No"
                                Binding="{Binding CollectorNumber}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Bottom filter bar -->
                    <Border Grid.Row="3"
                            Style="{DynamicResource FilterBarStyle}">
                        <DockPanel>
                            <Button Name="BtnBottomFilterCustomize"
                                    Content="Customize"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="4,0"
                                    Click="BtnBottomFilterCustomize_Click"/>
                            <Button Name="BtnBottomFilterClear"
                                    Content="Clear"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="0,0,2,0"
                                    Click="BtnBottomFilterClear_Click"/>
                            <CheckBox Name="ChkBottomFilter"
                                      IsChecked="False"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0"
                                      DockPanel.Dock="Left"
                                      Checked="ChkBottomFilter_Changed"
                                      Unchecked="ChkBottomFilter_Changed"/>
                            <TextBlock Name="BottomFilterSummary"
                                       Text="No filter active"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Splitter between top and bottom tables -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Background="{DynamicResource BorderBrush}"
                              Cursor="SizeNS"
                              Margin="0,-2,0,0"/>

            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             ROW 3 — STATUS BAR
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource AccentBrush}">
            <DockPanel Margin="8,0">
                <TextBlock Name="StatusText"
                           Foreground="White"
                           FontSize="11"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <TextBlock Name="RowCountText"
                           Foreground="White"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
