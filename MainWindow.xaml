<Window x:Class="BreakersOfE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Breakers of E"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ── Gripper template for column resizing ── -->
        <ControlTemplate x:Key="GripperTemplate" TargetType="Thumb">
            <Border Background="Transparent"/>
        </ControlTemplate>

        <!-- ── DataGrid column header with hover funnel + sort arrow ── -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="6,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="3"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Content}"
                                       Padding="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Path Grid.Column="1" Name="SortArrow"
                                  Visibility="Collapsed"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Width="8" Height="5" Stretch="Fill"
                                  Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5">
                                <Path.Data>
                                    <PathGeometry>M 0,0 L 4,4 L 8,0 Z</PathGeometry>
                                </Path.Data>
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                            <Button Grid.Column="2" Name="FunnelButton"
                                    Width="18" Height="18" Margin="0,0,4,0"
                                    Padding="0" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Visibility="Hidden" VerticalAlignment="Center"
                                    Tag="{TemplateBinding Content}"
                                    Click="ColumnFunnel_Click">
                                <TextBlock Name="FunnelIcon" Text="&#xE16E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="Gray"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>
                            <!-- Resize grippers -->
                            <Thumb x:Name="PART_LeftHeaderGripper"
                                   Grid.ColumnSpan="3"
                                   HorizontalAlignment="Left"
                                   Width="8" Cursor="SizeWE"
                                   Template="{StaticResource GripperTemplate}"/>
                            <Thumb x:Name="PART_RightHeaderGripper"
                                   Grid.ColumnSpan="3"
                                   HorizontalAlignment="Right"
                                   Width="8" Cursor="SizeWE"
                                   Template="{StaticResource GripperTemplate}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FunnelButton" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="4" CenterY="2.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="0" CenterX="4" CenterY="2.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid row style ── -->
        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{Binding RowForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="MinHeight"  Value="26"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="0,1,0,1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid cell style ── -->
        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="{Binding CellBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{Binding RowForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Summary row style ── -->
        <Style x:Key="SummaryBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>

        <!-- ── Deck tab style ── -->
        <Style x:Key="DeckTabStyle" TargetType="TabItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="8,3"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- ══ ROW 0 — MENU BAR ══ -->
        <Menu Grid.Row="0"
              Background="{DynamicResource SurfaceAltBrush}"
              Foreground="{DynamicResource PrimaryTextBrush}"
              FontSize="13">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="_File">
                <MenuItem Header="_New Deck..."      Click="MenuNewDeck_Click"/>
                <MenuItem Header="_Open Deck..."     Click="MenuOpenDeck_Click"/>
                <MenuItem Header="_Save Deck"        Name="MenuSaveDeck"      IsEnabled="False" Click="MenuSaveDeck_Click"/>
                <MenuItem Header="Save _All Decks"   Name="MenuSaveAllDecks"  IsEnabled="False" Click="MenuSaveAllDecks_Click"/>
                <MenuItem Header="Close _All Decks"  Name="MenuCloseAllDecks" IsEnabled="False" Click="MenuCloseAllDecks_Click"/>
                <Separator/>
                <MenuItem Header="_Preferences"      Click="MenuPreferences_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"             Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Theme">
                    <MenuItem Header="_Light Mode" Click="MenuThemeLight_Click"/>
                    <MenuItem Header="_Dark Mode"  Click="MenuThemeDark_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Update Card Database" Click="MenuUpdateDatabase_Click"/>
                <MenuItem Header="_Update Prices Only"   Click="MenuUpdatePrices_Click"/>
                <Separator/>
                <MenuItem Header="_Settings"             Click="MenuSettings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ══ ROW 1 — TOOLBAR ══ -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel Margin="4,2" Orientation="Horizontal">

                <!-- GROUP 1: DECK FILE -->
                <Button Name="BtnNewDeck"          Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE132;" ToolTip="New Deck"              IsEnabled="False" Click="BtnNewDeck_Click"         Margin="2,2"/>
                <Button Name="BtnOpenDeck"         Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE1A5;" ToolTip="Open Deck"             IsEnabled="False" Click="BtnOpenDeck_Click"        Margin="2,2"/>
                <Button Name="BtnSaveDeck"         Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE105;" ToolTip="Save Deck"             IsEnabled="False" Click="BtnSaveDeck_Click"        Margin="2,2"/>
                <Button Name="BtnSaveAllDecks"     Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE116;" ToolTip="Save All Decks"        IsEnabled="False" Click="BtnSaveAllDecks_Click"    Margin="2,2"/>
                <Button Name="BtnCloseAllDecks"    Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE10A;" ToolTip="Close All Decks"       IsEnabled="False" Click="BtnCloseAllDecks_Click"   Margin="2,2"/>
                <Button Name="BtnDeckProperties"   Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE946;" ToolTip="Deck Properties"       IsEnabled="False" Click="BtnDeckProperties_Click"  Margin="2,2"/>
                <Button Name="BtnDeckLegality"     Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE1C6;" ToolTip="Deck Legality"         IsEnabled="False" Click="BtnDeckLegality_Click"    Margin="2,2"/>
                <Button Name="BtnDeckStats"        Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE9F9;" ToolTip="Deck Statistics"       IsEnabled="False" Click="BtnDeckStats_Click"       Margin="2,2"/>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}" Margin="4,2"/>

                <!-- GROUP 2: DECK CARDS -->
                <Button Name="BtnAddToDeck"        Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE109;" ToolTip="Add 1 Card to Deck"              IsEnabled="False" Click="BtnAddToDeck_Click"       Margin="2,2"/>
                <Button Name="BtnAdd4ToDeck"       Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE1FE;" ToolTip="Add 4 Cards to Deck (Standard)"  IsEnabled="False" Click="BtnAdd4ToDeck_Click"      Margin="2,2"/>
                <Button Name="BtnAddFoilToDeck"    Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE1D9;" ToolTip="Add 1 Foil Card to Deck"         IsEnabled="False" Click="BtnAddFoilToDeck_Click"   Margin="2,2"/>
                <Button Name="BtnRemoveFromDeck"   Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE108;" ToolTip="Remove Card from Deck"           IsEnabled="False" Click="BtnRemoveFromDeck_Click"  Margin="2,2"/>
                <Button Name="BtnDeckQtyIncrease"  Style="{DynamicResource ToolbarButtonStyle}" ToolTip="Increase Qty in Deck"  IsEnabled="False" Click="BtnDeckQtyIncrease_Click" Margin="2,2">
                    <Button.Content>
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
                    </Button.Content>
                </Button>
                <Button Name="BtnDeckQtyDecrease"  Style="{DynamicResource ToolbarButtonStyle}" ToolTip="Decrease Qty in Deck"  IsEnabled="False" Click="BtnDeckQtyDecrease_Click" Margin="2,2">
                    <Button.Content>
                        <TextBlock Text="−" FontSize="16" FontWeight="Bold"/>
                    </Button.Content>
                </Button>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}" Margin="4,2"/>

                <!-- GROUP 3: COLLECTION -->
                <Button Name="BtnAddToCollection"      Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE109;" ToolTip="Add 1 Card to Collection"      IsEnabled="False" Click="BtnAddToCollection_Click"      Margin="2,2"/>
                <Button Name="BtnAddFoilToCollection"  Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE1D9;" ToolTip="Add 1 Foil Card to Collection"  IsEnabled="False" Click="BtnAddFoilToCollection_Click"  Margin="2,2"/>
                <Button Name="BtnRemoveFromCollection" Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE108;" ToolTip="Remove Card from Collection"    IsEnabled="False" Click="BtnRemoveFromCollection_Click" Margin="2,2"/>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}" Margin="4,2"/>

                <!-- GROUP 4: FILTER & SEARCH -->
                <Button Name="BtnFilter"         Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE16E;" ToolTip="Filter Cards"                  Click="BtnFilter_Click"         Margin="2,2"/>
                <Button Name="BtnAdvancedFilter" Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE16F;" ToolTip="Advanced Filter"               Click="BtnAdvancedFilter_Click" Margin="2,2"/>
                <Button Name="BtnSearch"         Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE11A;" ToolTip="Search for Card"               Click="BtnSearch_Click"         Margin="2,2"/>
                <Button Name="BtnFindNext"       Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE111;" ToolTip="Find Next"                     Click="BtnFindNext_Click"       Margin="2,2"/>
                <Button Name="BtnFindPrev"       Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE112;" ToolTip="Find Previous"                 Click="BtnFindPrev_Click"       Margin="2,2"/>
                <Button Name="BtnClearSearch"    Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE10A;" ToolTip="Cancel Incremental Search"     Click="BtnClearSearch_Click"    Margin="2,2"/>
                <Button Name="BtnToggleLegality" Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE14C;" ToolTip="Toggle Legality Columns"       Click="BtnLegality_Click"       Margin="2,2"/>
                <Button Name="BtnColumnChooser"  Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE179;" ToolTip="Show/Hide Columns"             Click="BtnColumnChooser_Click"  Margin="2,2"/>

                <Separator Style="{DynamicResource ToolbarSeparatorStyle}" Margin="4,2"/>

                <!-- GROUP 5: VIEW -->
                <Button Name="BtnUpdateDb" Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE117;" ToolTip="Update Card Database" Click="BtnUpdateDb_Click" Margin="2,2"/>
                <Button Name="BtnTheme"    Style="{DynamicResource ToolbarButtonStyle}" Content="&#xE706;" ToolTip="Toggle Light/Dark Mode" Click="BtnTheme_Click"  Margin="2,2"/>

                <!-- Mode dropdown -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,2,4,2">
                    <TextBlock Text="Mode:" Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Name="ViewModeComboBox"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Width="220" Height="28"
                              SelectionChanged="ViewModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Pool → Collection"  Tag="PoolToCollection"/>
                        <ComboBoxItem Content="Pool → Planechase"  Tag="PoolToPlanechase"/>
                        <ComboBoxItem Content="Pool → Archenemy"   Tag="PoolToArchenemy"/>
                        <ComboBoxItem Content="Pool → Vanguard"    Tag="PoolToVanguard"/>
                        <ComboBoxItem Content="Pool → Tokens"      Tag="PoolToTokens"/>
                        <ComboBoxItem Content="Pool → Art Series"  Tag="PoolToArtSeries"/>
                        <ComboBoxItem Content="Pool → Deck"        Tag="PoolToDeck"/>
                        <ComboBoxItem Content="Collection → Deck"  Tag="CollectionToDeck"/>
                    </ComboBox>
                </StackPanel>

            </WrapPanel>
        </Border>

        <!-- ══ ROW 2 — MAIN CONTENT ══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Border Name="CardImageBorder" Width="223" Height="310"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Margin="0,6,0,10" HorizontalAlignment="Center">
                            <Image Name="CardImage" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="NAME"             Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailName"       Style="{DynamicResource DetailValueStyle}" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="MANA COST"        Style="{DynamicResource DetailLabelStyle}"/>
                        <WrapPanel Name="DetailManaCostPanel" Margin="0,2,0,0"/>
                        <TextBlock Text="TYPE"             Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailType"       Style="{DynamicResource DetailValueStyle}"/>
                        <TextBlock Text="SET"              Style="{DynamicResource DetailLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Image Name="DetailSetSymbol" Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Name="DetailSet" Style="{DynamicResource DetailValueStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="COLLECTOR NUMBER" Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailCollectorNumber" Style="{DynamicResource DetailValueStyle}"/>
                        <TextBlock Text="RARITY"           Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailRarity"     Style="{DynamicResource DetailValueStyle}"/>
                        <TextBlock Name="DetailPTLabel"    Text="POWER / TOUGHNESS" Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailPT"         Style="{DynamicResource DetailValueStyle}"/>
                        <TextBlock Text="ORACLE TEXT"      Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailOracle"     Style="{DynamicResource DetailValueStyle}" FontSize="12"/>
                        <TextBlock Text="FLAVOR TEXT"      Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailFlavor"     Style="{DynamicResource DetailValueStyle}" FontSize="12" FontStyle="Italic" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="ARTIST"           Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailArtist"     Style="{DynamicResource DetailValueStyle}"/>
                        <TextBlock Text="AVAILABLE AS"     Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailFoilNonFoil" Style="{DynamicResource DetailValueStyle}"/>
                        <TextBlock Text="PRICES (USD)"     Style="{DynamicResource DetailLabelStyle}"/>
                        <TextBlock Name="DetailPrices"     Style="{DynamicResource DetailValueStyle}" FontSize="12"/>
                        <TextBlock Text="FORMAT LEGALITY"  Style="{DynamicResource DetailLabelStyle}"/>
                        <StackPanel Name="DetailLegalityPanel" Margin="0,2,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" Cursor="SizeWE"/>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- TOP TABLE -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <!-- Top bar -->
                    <Border Grid.Row="0" Style="{DynamicResource GroupByBarStyle}">
                        <TextBlock Text="Hover a column header to filter"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12" VerticalAlignment="Center" Margin="6,0"/>
                    </Border>

                    <!-- Search bar -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="8,4">
                        <DockPanel>
                            <TextBlock Text="&#xE11A;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                            <TextBlock Name="TopSearchLabel" Text="Pool"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontWeight="SemiBold" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                            <TextBox Name="SearchBox"
                                     Style="{DynamicResource BaseTextBoxStyle}"
                                     Height="28" Width="300"
                                     VerticalContentAlignment="Center"
                                     DockPanel.Dock="Left"
                                     TextChanged="SearchBox_TextChanged"/>
                        </DockPanel>
                    </Border>

                    <!-- Top DataGrid -->
                    <DataGrid Name="TopDataGrid" Grid.Row="2"
                              RowDetailsVisibilityMode="Collapsed"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" GotFocus="TopDataGrid_GotFocus"
                              SelectionUnit="FullRow" HeadersVisibility="Column"
                              SelectionChanged="TopDataGrid_SelectionChanged"
                              PreviewKeyDown="TopDataGrid_PreviewKeyDown"
                              Background="{DynamicResource GridRowBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0" GridLinesVisibility="None"
                              RowHeaderWidth="0" RowHeight="28"
                              CanUserResizeRows="True" CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle}"
                              RowStyle="{DynamicResource DataGridRowStyle}"
                              CellStyle="{DynamicResource DataGridCellStyle}">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                  Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        </DataGrid.Resources>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#F5F8FF"
                BorderBrush="#CCDDEE"
                BorderThickness="0,1,0,1"
                Padding="32,6,8,6">
                                    <StackPanel>
                                        <TextBlock Text="USED IN DECKS"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#666666"
                           Margin="0,0,0,4"/>
                                        <DataGrid Name="DeckUsageGrid"
                          ItemsSource="{Binding DeckUsageRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          BorderThickness="1"
                          BorderBrush="#CCDDEE"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          RowHeight="24"
                          MaxHeight="160"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          Background="White">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Deck Name" Binding="{Binding DeckName}" Width="200"/>
                                                <DataGridTextColumn Header="Type"      Binding="{Binding DeckType}" Width="90"/>
                                                <DataGridTextColumn Header="Qty"       Binding="{Binding Quantity}" Width="45"/>
                                                <DataGridTextColumn Header="Category"  Binding="{Binding Category}" Width="90"/>
                                                <DataGridTextColumn Header="Foil"      Binding="{Binding IsFoil}"   Width="50"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <!-- Expand/collapse deck usage -->
                            <DataGridTemplateColumn Header="" Width="28" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ExpandGlyph}"
                    Visibility="{Binding ExpandButtonVisibility}"
                    Width="20" Height="20"
                    FontSize="14" FontWeight="Bold"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Tag="{Binding}"
                    Click="BtnExpandDeckUsage_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="★"  Width="28"  CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FavoriteGlyph}" HorizontalAlignment="Center" Foreground="Gold" FontSize="13"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ES" Width="32"  CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding SetSymbolPath, Converter={StaticResource ImageSourceConverter}}"
                                               Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name"         Binding="{Binding Name}"                Width="200"/>
                            <DataGridTextColumn Header="Edition"      Binding="{Binding SetCode}"            Width="60"/>
                            <DataGridTextColumn Header="Edition Name" Binding="{Binding SetName}"            Width="160"/>
                            <DataGridTextColumn Header="Color"        Binding="{Binding ColorDisplay}" Width="50"/>
                            <DataGridTextColumn Header="Color ID"     Binding="{Binding ColorIdentity}" Width="80"/>
                            <DataGridTextColumn Header="Type"         Binding="{Binding TypeLine}"           Width="180"/>
                            <DataGridTextColumn Header="Rarity"       Binding="{Binding RarityCode}"         Width="50"/>
                            <DataGridTemplateColumn Header="Cost" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentPresenter Content="{Binding ManaCost, Converter={StaticResource ManaCostConverter}}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="P/T"          Binding="{Binding PowerToughness}"     Width="55"/>
                            <DataGridTextColumn Header="USD"          Binding="{Binding PriceUsdDisplay}"    Width="70"/>
                            <DataGridTextColumn Header="USD Foil"     Binding="{Binding PriceUsdFoilDisplay}" Width="75"/>
                            <DataGridTextColumn Header="Text"         Binding="{Binding OracleText}"         Width="220"/>
                            <DataGridTextColumn Header="Flavor"       Binding="{Binding FlavorText}"         Width="160"/>
                            <DataGridTextColumn Header="Artist"       Binding="{Binding Artist}"             Width="130"/>
                            <DataGridTextColumn Header="No"           Binding="{Binding CollectorNumber}"    Width="55"/>
                            <DataGridTextColumn Header="Power"        Binding="{Binding Power}"              Width="50"/>
                            <DataGridTextColumn Header="Toughness"    Binding="{Binding Toughness}"          Width="70"/>
                            <DataGridTextColumn Header="CMC"          Binding="{Binding ManaValue}"          Width="45"/>
                            <DataGridTextColumn Header="Standard"     Binding="{Binding LegalityStandard}"   Width="70" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Pioneer"      Binding="{Binding LegalityPioneer}"    Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Modern"       Binding="{Binding LegalityModern}"     Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Legacy"       Binding="{Binding LegalityLegacy}"     Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Vintage"      Binding="{Binding LegalityVintage}"    Width="65" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Commander"    Binding="{Binding LegalityCommander}"  Width="80" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Pauper"       Binding="{Binding LegalityPauper}"     Width="65" Visibility="Collapsed"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Top filter bar -->
                    <Border Grid.Row="3" Style="{DynamicResource FilterBarStyle}">
                        <DockPanel>
                            <Button Name="BtnTopFilterCustomize" Content="Customize"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="4,0"
                                    Click="BtnTopFilterCustomize_Click"/>
                            <Button Name="BtnTopFilterClear" Content="Clear"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="0,0,2,0"
                                    Click="BtnTopFilterClear_Click"/>
                            <CheckBox Name="ChkTopFilter" IsChecked="False"
                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                      DockPanel.Dock="Left"
                                      Checked="ChkTopFilter_Changed"
                                      Unchecked="ChkTopFilter_Changed"/>
                            <TextBlock Name="TopFilterSummary" Text="No filter active"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- ACTION BAR + SPLITTER -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,1" Padding="8,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Name="ActionBarLabel" Text=""
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Background="{DynamicResource BorderBrush}"
                              Cursor="SizeNS" Margin="0,-2,0,0"/>

                <!-- BOTTOM AREA -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- Bottom label bar -->
                    <Border Grid.Row="0" Style="{DynamicResource GroupByBarStyle}">
                        <DockPanel Margin="6,0">
                            <TextBlock Name="BottomTableLabel" Text="Collection"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        </DockPanel>
                    </Border>

                    <!-- COLLECTION DataGrid -->
                    <DataGrid Name="BottomDataGrid" Grid.Row="1"
                              RowDetailsVisibilityMode="Collapsed"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              SelectionMode="Single" GotFocus="BottomDataGrid_GotFocus"
                              SelectionUnit="FullRow" HeadersVisibility="Column"
                              SelectionChanged="BottomDataGrid_SelectionChanged"
                              Background="{DynamicResource GridRowBrush}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              BorderThickness="0" GridLinesVisibility="None"
                              RowHeaderWidth="0" RowHeight="28"
                              CanUserResizeRows="True" CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle}"
                              RowStyle="{DynamicResource DataGridRowStyle}"
                              CellStyle="{DynamicResource DataGridCellStyle}">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                  Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        </DataGrid.Resources>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove 1 Copy"     Click="CtxRemove1_Click"/>
                                <MenuItem Header="Remove All Copies"  Click="CtxRemoveAll_Click"/>
                                <Separator/>
                                <MenuItem Header="Show Deck Usage"   Click="CtxShowDeckUsage_Click"/>
                                <Separator/>
                                <MenuItem Header="View Card Details"  Click="CtxViewDetails_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#F5F8FF"
                                    BorderBrush="#CCDDEE"
                                    BorderThickness="0,1,0,1"
                                    Padding="32,6,8,6">
                                <StackPanel>
                                    <TextBlock Text="USED IN DECKS"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="#666666"
                                        Margin="0,0,0,4"/>
                                    <DataGrid Name="DeckUsageGrid"
                          ItemsSource="{Binding DeckUsageRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          BorderThickness="1"
                          BorderBrush="#CCDDEE"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          RowHeight="24"
                          MaxHeight="160"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          Background="White">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Deck Name" Binding="{Binding DeckName}" Width="200"/>
                                                <DataGridTextColumn Header="Type"      Binding="{Binding DeckType}" Width="90"/>
                                                <DataGridTextColumn Header="Qty"       Binding="{Binding Quantity}" Width="45"/>
                                                <DataGridTextColumn Header="Category"  Binding="{Binding Category}" Width="90"/>
                                                <DataGridTextColumn Header="Foil"      Binding="{Binding IsFoil}"   Width="50"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <!-- Expand/collapse deck usage -->
                            <DataGridTemplateColumn Header="" Width="28" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ExpandGlyph}"
                    Visibility="{Binding ExpandButtonVisibility}"
                    Width="20" Height="20"
                    FontSize="14" FontWeight="Bold"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Tag="{Binding}"
                    Click="BtnExpandDeckUsage_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="★"  Width="28"  CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FavoriteGlyph}" HorizontalAlignment="Center" Foreground="Gold" FontSize="13"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ES" Width="32"  CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding SetSymbolPath, Converter={StaticResource ImageSourceConverter}}"
                                               Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name"         Binding="{Binding Name}"            Width="200"/>
                            <DataGridTextColumn Header="Edition"      Binding="{Binding SetCode}"         Width="60"/>
                            <DataGridTextColumn Header="Edition Name" Binding="{Binding SetName}"         Width="160"/>
                            <!-- Qty spinner -->
                            <DataGridTemplateColumn Header="Qty" Width="95">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding Quantity}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Content="−" Width="22" Height="20" FontSize="13" Padding="0" Tag="{Binding}" Click="BtnQtyMinus_Row_Click"/>
                                                <TextBox Width="34" Height="20" Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" FontSize="13" Padding="0" BorderThickness="1" Tag="{Binding}" TextChanged="TxtQtyRow_TextChanged" PreviewKeyDown="TxtQtyRow_KeyDown"/>
                                                <Button Content="+" Width="22" Height="20" FontSize="13" Padding="0" Tag="{Binding}" Click="BtnQtyPlus_Row_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Foil Qty spinner -->
                            <DataGridTemplateColumn Header="Foil Qty" Width="105">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding FoilQuantity}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Content="−" Width="22" Height="20" FontSize="13" Padding="0" Tag="{Binding}" Click="BtnFoilQtyMinus_Row_Click"/>
                                                <TextBox Width="34" Height="20" Text="{Binding FoilQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" FontSize="13" Padding="0" BorderThickness="1" Tag="{Binding}" TextChanged="TxtFoilQtyRow_TextChanged" PreviewKeyDown="TxtFoilQtyRow_KeyDown"/>
                                                <Button Content="+" Width="22" Height="20" FontSize="13" Padding="0" Tag="{Binding}" Click="BtnFoilQtyPlus_Row_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Used"        Binding="{Binding UsedCount}"           Width="50"/>
                            <DataGridTextColumn Header="Available"   Binding="{Binding AvailableCount}"      Width="75"/>
                            <DataGridTextColumn Header="USD"         Binding="{Binding PriceUsdDisplay}"     Width="70"/>
                            <DataGridTextColumn Header="USD Foil"    Binding="{Binding PriceUsdFoilDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Value"       Binding="{Binding ValueDisplay}"        Width="75"/>
                            <DataGridTextColumn Header="Foil Value"  Binding="{Binding FoilValueDisplay}"    Width="80"/>
                            <DataGridTextColumn Header="Total Value" Binding="{Binding TotalValueDisplay}"   Width="85"/>
                            <DataGridTextColumn Header="Color"       Binding="{Binding ColorDisplay}" Width="50"/>
                            <DataGridTextColumn Header="Color ID"    Binding="{Binding ColorIdentity}" Width="80"/>
                            <DataGridTextColumn Header="Type"        Binding="{Binding TypeLine}"            Width="160"/>
                            <DataGridTextColumn Header="Rarity"      Binding="{Binding RarityCode}"          Width="50"/>
                            <DataGridTemplateColumn Header="Cost" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentPresenter Content="{Binding ManaCost, Converter={StaticResource ManaCostConverter}}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="P/T"         Binding="{Binding PowerToughness}"      Width="55"/>
                            <DataGridTextColumn Header="Condition"   Binding="{Binding Condition}"           Width="85"/>
                            <DataGridTextColumn Header="Language"    Binding="{Binding Language}"            Width="75"/>
                            <DataGridTextColumn Header="Storage"     Binding="{Binding StorageLocation}"     Width="100"/>
                            <DataGridTextColumn Header="Artist"      Binding="{Binding Artist}"              Width="130"/>
                            <DataGridTextColumn Header="No"          Binding="{Binding CollectorNumber}"     Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- DECK TabControl — shown in deck modes only -->
                    <TabControl Name="DeckTabControl" Grid.Row="1"
                                TabStripPlacement="Bottom"
                                Visibility="Collapsed"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                SelectionChanged="DeckTabControl_SelectionChanged">
                        <!-- Deck tabs added dynamically in code-behind -->
                    </TabControl>

                    <!-- Bottom filter bar -->
                    <Border Grid.Row="2" Style="{DynamicResource FilterBarStyle}">
                        <DockPanel>
                            <Button Name="BtnBottomFilterCustomize" Content="Customize"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="4,0"
                                    Click="BtnBottomFilterCustomize_Click"/>
                            <Button Name="BtnBottomFilterClear" Content="Clear"
                                    Style="{DynamicResource BaseButtonStyle}"
                                    Height="20" FontSize="11" Padding="6,1"
                                    DockPanel.Dock="Right" Margin="0,0,2,0"
                                    Click="BtnBottomFilterClear_Click"/>
                            <CheckBox Name="ChkBottomFilter" IsChecked="False"
                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                      DockPanel.Dock="Left"
                                      Checked="ChkBottomFilter_Changed"
                                      Unchecked="ChkBottomFilter_Changed"/>
                            <TextBlock Name="BottomFilterSummary" Text="No filter active"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Border>

                    <!-- Frozen summary row -->
                    <Border Grid.Row="3" Style="{DynamicResource SummaryBorderStyle}">
                        <DockPanel>
                            <TextBlock Name="SummaryText" Text=""
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <TextBlock Name="SummaryValueText" Text=""
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       DockPanel.Dock="Right" Margin="0,0,8,0"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══ ROW 3 — STATUS BAR ══ -->
        <Border Grid.Row="3" Background="{DynamicResource AccentBrush}">
            <DockPanel Margin="8,0">
                <TextBlock Name="StatusText"   Foreground="White" FontSize="12" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <TextBlock Name="RowCountText" Foreground="White" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
