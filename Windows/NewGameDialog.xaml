<Window x:Class="BreakersOfE.Windows.NewGameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Game Setup"
        Width="480" Height="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#F0F0F0">
    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4444AA"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333388"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsHighlighted" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#2A2A3E"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#555577"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="New Game Setup"
                   FontSize="16" FontWeight="Bold" Foreground="#333"/>

        <!-- Player 1 -->
        <GroupBox Grid.Row="2" Header="Player 1 (You)" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name:"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" Name="Player1NameBox"
                         Text="Player 1" Height="26" FontSize="12"
                         VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Deck:"
                           VerticalAlignment="Center" FontSize="12"/>
                <ComboBox Grid.Column="4" Name="Player1DeckCombo"
                          Height="26" FontSize="11"
                          SelectionChanged="DeckCombo_SelectionChanged"/>
            </Grid>
        </GroupBox>

        <!-- Player 2 -->
        <GroupBox Grid.Row="4" Header="Player 2 (Opponent)" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name:"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBox Grid.Column="1" Name="Player2NameBox"
                         Text="Player 2" Height="26" FontSize="12"
                         VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Deck:"
                           VerticalAlignment="Center" FontSize="12"/>
                <ComboBox Grid.Column="4" Name="Player2DeckCombo"
                          Height="26" FontSize="11"
                          SelectionChanged="DeckCombo_SelectionChanged"/>
            </Grid>
        </GroupBox>

        <!-- Game Options -->
        <GroupBox Grid.Row="6" Header="Game Options" Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Starting Life:" VerticalAlignment="Center"
                           FontSize="12" Margin="0,0,8,0"/>
                <TextBox Name="StartingLifeBox" Text="40" Width="50"
                         Height="26" FontSize="12" TextAlignment="Center"
                         VerticalContentAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Name="DeckTypeLabel" Text="(Commander detected)"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="#888"/>
            </StackPanel>
        </GroupBox>



        <!-- Info label -->
        <TextBlock Grid.Row="10" Name="InfoLabel"
                   Text="Select decks to begin, or leave blank to start with an empty table."
                   FontSize="11" Foreground="#666" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Tip: Leave Player 2 deck blank to goldfish (solo test) your deck."
                       FontSize="10" Foreground="#888" VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
            <Button Grid.Column="1" Name="BtnCancel" Content="Cancel"
                    Width="80" Height="32" FontSize="12" IsCancel="True"
                    Click="BtnCancel_Click"/>
            <Button Grid.Column="3" Name="BtnStart" Content="▶  Begin"
                    Width="120" Height="32" FontSize="13" FontWeight="SemiBold"
                    IsDefault="True" Background="#2255AA" Foreground="White"
                    BorderBrush="#1A4499" Click="BtnStart_Click"/>
        </Grid>
    </Grid>
</Window>
