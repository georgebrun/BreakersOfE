<Window x:Class="BreakersOfE.Windows.DeckStatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deck Statistics"
        Width="960" Height="600"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F0F0F0">
    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4444AA"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333388"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsHighlighted" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#2A2A3E"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4444AA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Name="MainTabControl"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    Background="#F0F0F0" BorderThickness="0,1,0,0"
                    BorderBrush="#CCCCCC">

            <!-- ══ TAB 1 — COLORS ══ -->
            <TabItem Header="Colors">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Card breakdown by card colors."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Canvas Name="ColorsPieCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="PieCanvas_SizeChanged"/>
                    </Grid>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,6">
                        <WrapPanel Name="ColorsLegendPanel"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 2 — RARITY ══ -->
            <TabItem Header="Rarity">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Card breakdown by card rarity."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Canvas Name="RarityPieCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="PieCanvas_SizeChanged"/>
                    </Grid>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,6">
                        <WrapPanel Name="RarityLegendPanel"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 3 — CARD TYPE ══ -->
            <TabItem Header="Card Type">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Details Level:" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="CardTypeDetailCombo" Width="120" Height="24"
                                  FontSize="12"
                                  SelectionChanged="CardTypeDetailCombo_SelectionChanged">
                            <ComboBoxItem Content="General" IsSelected="True"/>
                            <ComboBoxItem Content="Main"/>
                            <ComboBoxItem Content="Detailed"/>
                        </ComboBox>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Canvas Name="CardTypePieCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="PieCanvas_SizeChanged"/>
                    </Grid>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,6">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <WrapPanel Name="CardTypeLegendPanel"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 4 — EDITIONS ══ -->
            <TabItem Header="Editions">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Card breakdown by editions."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <DataGrid Grid.Row="1" Name="EditionsGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0" RowHeaderWidth="0"
                              RowHeight="22" FontSize="12"
                              CanUserResizeRows="False" CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Edition"
                                               Binding="{Binding SetName}" Width="*"/>
                            <DataGridTextColumn Header="Abbreviation"
                                               Binding="{Binding SetCode}" Width="100"/>
                            <DataGridTextColumn Header="Quantity"
                                               Binding="{Binding Quantity}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 5 — MANA ANALYSER ══ -->
            <TabItem Header="Mana Analyser">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Detailed mana breakdown by colors and turns."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="8,4,4,4"
                                BorderBrush="#AAA" BorderThickness="1" Background="White">
                            <Canvas Name="ManaCurveCanvas" SizeChanged="PieCanvas_SizeChanged"/>
                        </Border>
                        <Grid Grid.Column="1" Margin="0,4,8,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Manalyser" FontWeight="SemiBold"
                                       FontSize="11" HorizontalAlignment="Center"
                                       Margin="0,2,0,4"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <WrapPanel Name="ManalyserPanel" Orientation="Horizontal"/>
                            </ScrollViewer>
                            <StackPanel Grid.Row="2" Name="AvgCostPanel" Margin="0,4,0,0">
                                <TextBlock Text="Average Cost:" FontSize="10"
                                           FontWeight="SemiBold" Margin="0,0,0,2"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="12,6">
                        <WrapPanel Name="ManaStatsPanel" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 6 — MANA PRODUCT ══ -->
            <TabItem Header="Mana Product">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Mana production by turns."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="8,4,4,8"
                                BorderBrush="#AAA" BorderThickness="1" Background="White">
                            <Canvas Name="ManaProductCanvas" SizeChanged="PieCanvas_SizeChanged"/>
                        </Border>
                        <StackPanel Grid.Column="1" Name="ManaProductLegendPanel"
                                    Margin="4,8,8,8"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 7 — POWER ANALYSER ══ -->
            <TabItem Header="Power Analyser">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Power and Toughness by converted mana cost."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="8,4,4,8"
                                BorderBrush="#AAA" BorderThickness="1" Background="White">
                            <Canvas Name="PowerAnalyserCanvas" SizeChanged="PieCanvas_SizeChanged"/>
                        </Border>
                        <StackPanel Grid.Column="1" Name="PowerLegendPanel"
                                    Margin="4,8,8,8"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 8 — PROBABILITY ══ -->
            <TabItem Header="Probability">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Detailed turn breakdown by drawing cards probability.&#x0a;Probability is the measure of how likely an event is."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555" TextAlignment="Center"/>
                    <!-- Card list with Desired Qty -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid Grid.Column="0" Name="ProbabilityGrid"
                                  AutoGenerateColumns="False" IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1" BorderBrush="#CCC"
                                  RowHeaderWidth="0" RowHeight="22" FontSize="12"
                                  CanUserResizeRows="False" CanUserReorderColumns="False"
                                  Margin="8,4,4,4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Card Name"
                                                   Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Deck Qty"
                                                   Binding="{Binding DeckQty}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Desired Qty"
                                                   Binding="{Binding DesiredQty, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                   Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Column="1" Margin="4,8,8,4">
                            <TextBlock Text="Operator:" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                            <RadioButton Name="RadioAnd" Content="And" IsChecked="True"
                                         FontSize="11" Margin="0,2" GroupName="ProbOp"
                                         Checked="ProbabilityParam_Changed"/>
                            <RadioButton Name="RadioOr" Content="Or"
                                         FontSize="11" Margin="0,2" GroupName="ProbOp"
                                         Checked="ProbabilityParam_Changed"/>
                            <TextBlock Text="Mode:" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,4"/>
                            <RadioButton Name="RadioAtLeast" Content="At Least" IsChecked="True"
                                         FontSize="11" Margin="0,2" GroupName="ProbMode"
                                         Checked="ProbabilityParam_Changed"/>
                            <RadioButton Name="RadioExactly" Content="Exactly"
                                         FontSize="11" Margin="0,2" GroupName="ProbMode"
                                         Checked="ProbabilityParam_Changed"/>
                            <Button Name="BtnDescribe" Content="Describe"
                                    Width="80" Height="24" Margin="0,16,0,4"
                                    FontSize="11" Click="BtnDescribe_Click"/>
                            <Button Name="BtnClearProb" Content="Clear"
                                    Width="80" Height="24" Margin="0,4"
                                    FontSize="11" Click="BtnClearProb_Click"/>
                        </StackPanel>
                    </Grid>
                    <!-- Probability bars -->
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Probability of drawing current combo:"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <StackPanel Name="ProbBarsPanel" Orientation="Horizontal"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Turn" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBox Name="TurnBox" Text="10" Width="50" Height="22"
                                         FontSize="11" HorizontalAlignment="Center"
                                         TextAlignment="Center"
                                         TextChanged="TurnBox_TextChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 9 — MANA SLOTS ══ -->
            <TabItem Header="Mana Slots">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Mana Slots analysis (known as George Baxter Analysis) allows you to evaluate the actual mana required to play the cards."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="11" Foreground="#555" TextWrapping="Wrap"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid Grid.Column="0" Name="ManaSlotsGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1" BorderBrush="#CCC"
                                  RowHeaderWidth="0" RowHeight="22" FontSize="12"
                                  CanUserResizeRows="False" CanUserReorderColumns="False"
                                  Margin="8,4,4,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Card" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="45"/>
                                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="80"/>
                                <DataGridTextColumn Header="Importance" Binding="{Binding Importance}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Column="1" Margin="4,8,8,8">
                            <TextBlock Text="Needed Mana Slots:" FontWeight="SemiBold"
                                       FontSize="11" Margin="0,0,0,6"/>
                            <StackPanel Name="ManaSlotsPanel"/>
                            <Separator Margin="0,8"/>
                            <TextBlock Name="TotalSlotsText" Text="Total slots: 0"
                                       FontWeight="SemiBold" FontSize="11"/>
                            <Button Content="Help" Width="60" Height="24"
                                    Margin="0,12,0,0" FontSize="11"
                                    HorizontalAlignment="Left"
                                    Click="BtnManaSlotsHelp_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 10 — START HAND ══ -->
            <TabItem Header="Start Hand">
                <Grid Margin="8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Controls bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Hand Size" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Name="HandSizeBox" Text="7" Width="40" Height="24"
                                 FontSize="11" TextAlignment="Center" VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <Button Content="New Hand" Width="75" Height="26" FontSize="11"
                                Margin="0,0,4,0" Click="BtnNewHand_Click"/>
                        <Button Content="Mulligan" Width="65" Height="26" FontSize="11"
                                Margin="0,0,4,0" Click="BtnMulligan_Click"/>
                        <Button Content="Draw Card" Width="75" Height="26" FontSize="11"
                                Margin="0,0,4,0" Click="BtnDrawCard_Click"/>
                        <Button Content="Draw All" Width="65" Height="26" FontSize="11"
                                Margin="0,0,4,0" Click="BtnDrawAll_Click"/>
                        <Button Content="Setup..." Width="65" Height="26" FontSize="11"
                                HorizontalAlignment="Right" Margin="20,0,0,0"
                                Click="BtnHandSetup_Click"/>
                    </StackPanel>
                    <!-- Three panels -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Deck -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Cards in Deck" FontWeight="SemiBold"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <ListBox Grid.Row="1" Name="DeckListBox"
                                     BorderBrush="#CCC" BorderThickness="1"
                                     FontSize="11"/>
                        </Grid>
                        <!-- Deck↔Hand arrows -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2">
                            <Button Content="▶▶" Height="26" FontSize="10" Margin="0,2"
                                    Click="BtnDeckToHand_Click" ToolTip="Move to Hand"/>
                            <Button Content="◀◀" Height="26" FontSize="10" Margin="0,2"
                                    Click="BtnHandToDeck_Click" ToolTip="Return to Deck"/>
                        </StackPanel>
                        <!-- Hand -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Cards in Hand" FontWeight="SemiBold"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <ListBox Grid.Row="1" Name="HandListBox"
                                     BorderBrush="#CCC" BorderThickness="1"
                                     FontSize="11"/>
                        </Grid>
                        <!-- Hand→Play/Discard arrows -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="2">
                            <Button Content="▶▶" Height="26" FontSize="10" Margin="0,2"
                                    Click="BtnHandToPlay_Click" ToolTip="Play Card"/>
                            <Button Content="◀◀" Height="26" FontSize="10" Margin="0,2"
                                    Click="BtnPlayToHand_Click" ToolTip="Return to Hand"/>
                            <Separator Margin="0,4"/>
                            <Button Content="▶▶" Height="26" FontSize="10" Margin="0,2"
                                    Click="BtnHandToDiscard_Click" ToolTip="Discard"/>
                            <Button Content="◀◀" Height="26" FontSize="10" Margin="0,2"
                                    Click="BtnDiscardToHand_Click" ToolTip="Return to Hand"/>
                        </StackPanel>
                        <!-- Play + Discard -->
                        <Grid Grid.Column="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Cards in Play" FontWeight="SemiBold"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <ListBox Grid.Row="1" Name="PlayListBox"
                                     BorderBrush="#CCC" BorderThickness="1"
                                     FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Text="Cards in Discard Pile" FontWeight="SemiBold"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <ListBox Grid.Row="3" Name="DiscardListBox"
                                     BorderBrush="#CCC" BorderThickness="1"
                                     FontSize="11"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 11 — ADVANCED ══ -->
            <TabItem Header="Advanced">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Descriptive statistics on main deck card characteristics."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <DataGrid Grid.Row="1" Name="AdvancedGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0" RowHeaderWidth="0"
                              RowHeight="22" FontSize="11"
                              CanUserResizeRows="False" CanUserReorderColumns="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Characteristic" Binding="{Binding Stat}"
                                               Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Background" Value="#ECECEC"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Power"        Binding="{Binding Power}"       Width="90"/>
                            <DataGridTextColumn Header="Toughness"    Binding="{Binding Toughness}"   Width="90"/>
                            <DataGridTextColumn Header="CMC"          Binding="{Binding CMC}"         Width="90"/>
                            <DataGridTextColumn Header="Mana Product" Binding="{Binding ManaProduct}" Width="110"/>
                            <DataGridTextColumn Header="# of Rules"   Binding="{Binding RuleCount}"   Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="1" Background="#F0F0F0"
                BorderBrush="#CCC" BorderThickness="0,1,0,0">
            <Button Content="Close" Width="80" Height="26"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,12,0" IsDefault="True" IsCancel="True"
                    Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
