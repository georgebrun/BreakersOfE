<Window x:Class="BreakersOfE.Windows.DeckStatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deck Statistics"
        Width="860" Height="580"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Name="MainTabControl"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    Background="#F0F0F0" BorderThickness="0,1,0,0"
                    BorderBrush="#CCCCCC">

            <!-- ══ TAB 1 — COLORS ══ -->
            <TabItem Header="Colors">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Card breakdown by card colors."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Canvas Grid.Row="1" Name="ColorsPieCanvas"/>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,6">
                        <WrapPanel Name="ColorsLegendPanel"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 2 — RARITY ══ -->
            <TabItem Header="Rarity">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Card breakdown by card rarity."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Canvas Grid.Row="1" Name="RarityPieCanvas"/>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,6">
                        <WrapPanel Name="RarityLegendPanel"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 3 — CARD TYPE ══ -->
            <TabItem Header="Card Type">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Details Level:" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="CardTypeDetailCombo" Width="120" Height="24"
                                  FontSize="12"
                                  SelectionChanged="CardTypeDetailCombo_SelectionChanged">
                            <ComboBoxItem Content="General" IsSelected="True"/>
                            <ComboBoxItem Content="Main"/>
                            <ComboBoxItem Content="Detailed"/>
                        </ComboBox>
                    </StackPanel>
                    <Canvas Grid.Row="1" Name="CardTypePieCanvas"/>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="8,6">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <WrapPanel Name="CardTypeLegendPanel"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 4 — EDITIONS ══ -->
            <TabItem Header="Editions">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Card breakdown by editions."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <DataGrid Grid.Row="1" Name="EditionsGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0" RowHeaderWidth="0"
                              RowHeight="22" FontSize="12"
                              CanUserResizeRows="False" CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Edition"
                                               Binding="{Binding SetName}" Width="*"/>
                            <DataGridTextColumn Header="Abbreviation"
                                               Binding="{Binding SetCode}" Width="100"/>
                            <DataGridTextColumn Header="Quantity"
                                               Binding="{Binding Quantity}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 5 — MANA ANALYSER ══ -->
            <TabItem Header="Mana Analyser">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Mana curve — card count by converted mana cost."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Border Grid.Row="1" Margin="8,4"
                            BorderBrush="#AAA" BorderThickness="1" Background="White">
                        <Canvas Name="ManaCurveCanvas"/>
                    </Border>
                    <Border Grid.Row="2" Background="#F8F8F8"
                            BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="12,8">
                        <WrapPanel Name="ManaStatsPanel" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ TAB 6 — MANA PRODUCT ══ -->
            <TabItem Header="Mana Product">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Mana production by turns."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="8,4,4,8"
                                BorderBrush="#AAA" BorderThickness="1" Background="White">
                            <Canvas Name="ManaProductCanvas"/>
                        </Border>
                        <StackPanel Grid.Column="1" Name="ManaProductLegendPanel"
                                    Margin="4,8,8,8"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 7 — POWER ANALYSER ══ -->
            <TabItem Header="Power Analyser">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Power and Toughness by converted mana cost."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="8,4,4,8"
                                BorderBrush="#AAA" BorderThickness="1" Background="White">
                            <Canvas Name="PowerAnalyserCanvas"/>
                        </Border>
                        <StackPanel Grid.Column="1" Name="PowerLegendPanel"
                                    Margin="4,8,8,8"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ TAB 8 — DECK LEGALITY ══ -->
            <TabItem Header="Legality">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Format legality for this deck."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <DataGrid Grid.Row="1" Name="LegalityGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0" RowHeaderWidth="0"
                              RowHeight="26" FontSize="12"
                              CanUserResizeRows="False" CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Format"
                                               Binding="{Binding Format}" Width="160"/>
                            <DataGridTextColumn Header="Status"
                                               Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Issues"
                                               Binding="{Binding Issues}" Width="*"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLegal}" Value="True">
                                        <Setter Property="Foreground" Value="#006600"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLegal}" Value="False">
                                        <Setter Property="Foreground" Value="#AA0000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="1" Background="#F0F0F0"
                BorderBrush="#CCC" BorderThickness="0,1,0,0">
            <Button Content="Close" Width="80" Height="26"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,12,0" IsDefault="True" IsCancel="True"
                    Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
