<Window x:Class="BreakersOfE.Windows.TabletopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tabletop Simulator"
        Width="1600" Height="1050"
        MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1A1A1A">

    <Window.Resources>
        <!-- Felt green radial gradient -->
        <RadialGradientBrush x:Key="FeltBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
            <GradientStop Color="#2D5A27" Offset="0.0"/>
            <GradientStop Color="#234820" Offset="0.5"/>
            <GradientStop Color="#152E14" Offset="1.0"/>
        </RadialGradientBrush>

        <!-- Wood grain linear gradient for border -->
        <LinearGradientBrush x:Key="WoodBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6B3A1F" Offset="0.0"/>
            <GradientStop Color="#8B4E2A" Offset="0.2"/>
            <GradientStop Color="#7A4422" Offset="0.4"/>
            <GradientStop Color="#9B5A30" Offset="0.6"/>
            <GradientStop Color="#6B3A1F" Offset="0.8"/>
            <GradientStop Color="#8B4E2A" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Rail gradient — raised wood center divider -->
        <LinearGradientBrush x:Key="RailBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#9B5A30" Offset="0.0"/>
            <GradientStop Color="#7A4422" Offset="0.15"/>
            <GradientStop Color="#5C3218" Offset="0.5"/>
            <GradientStop Color="#7A4422" Offset="0.85"/>
            <GradientStop Color="#9B5A30" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Rail shadow above -->
        <LinearGradientBrush x:Key="ShadowTopBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#88000000" Offset="0.0"/>
            <GradientStop Color="#00000000" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Rail shadow below -->
        <LinearGradientBrush x:Key="ShadowBottomBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00000000" Offset="0.0"/>
            <GradientStop Color="#88000000" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Zone label style — visible over playmat -->
        <Style x:Key="ZoneLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="4"
                                      ShadowDepth="1" Opacity="0.9"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zone border style — transparent, no overlay -->
        <Style x:Key="ZoneBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Control button style -->
        <Style x:Key="TableBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#44000000"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#66000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#88000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Info bar style -->
        <Style x:Key="InfoBarStyle" TargetType="Border">
            <Setter Property="Background" Value="#CC000000"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <!-- Life counter style -->
        <Style x:Key="LifeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Phase button style -->
        <Style x:Key="PhaseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#55FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivePhaseButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PhaseButtonStyle}">
            <Setter Property="Background" Value="#88D4AF37"/>
            <Setter Property="Foreground" Value="#FFE066"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- OUTER WOOD BORDER                                               -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Border Background="{StaticResource WoodBrush}" Padding="12">

        <!-- INNER FELT TABLE -->
        <Border Background="{StaticResource FeltBrush}"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Opponent info bar — outside playmat -->
                    <RowDefinition Height="36"/>
                    <!-- Opponent hand — hidden, count shown in info bar -->
                    <RowDefinition Name="OppHandRow" Height="0"/>
                    <!-- Opponent mana/land zone — opp playmat (closest to rail) -->
                    <RowDefinition Height="1*"/>
                    <!-- Opponent battlefield creatures/spells — opp playmat -->
                    <RowDefinition Height="2*"/>
                    <!-- Center rail — table edge between seats -->
                    <RowDefinition Height="44"/>
                    <!-- Your battlefield creatures/spells — your playmat -->
                    <RowDefinition Height="2*"/>
                    <!-- Your mana/land zone — your playmat (closest to rail) -->
                    <RowDefinition Height="1*"/>
                    <!-- Your hand — animated, collapses to peek strip -->
                    <RowDefinition Name="YourHandRow" Height="32"/>
                    <!-- Your info bar — outside playmat -->
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>


                <!-- ================================================== -->
                <!-- YOUR PLAYMAT — full player area (mana+field+hand)   -->
                <!-- ================================================== -->
                <Image Name="YourPlaymatImage"
                       Grid.Row="5" Grid.RowSpan="3"
                       Stretch="Fill"
                       Opacity="1.0"
                       IsHitTestVisible="False"
                       Panel.ZIndex="0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

                <!-- ================================================== -->
                <!-- OPP PLAYMAT — full opp area (hand+field+mana)       -->
                <!-- Rotated 180 to face opponent's direction            -->
                <!-- ================================================== -->
                <Image Name="OppPlaymatImage"
                       Grid.Row="1" Grid.RowSpan="3"
                       Stretch="Fill"
                       Opacity="1.0"
                       IsHitTestVisible="False"
                       Panel.ZIndex="0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <RotateTransform Angle="180"/>
                    </Image.RenderTransform>
                </Image>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 0 — OPPONENT INFO BAR                         -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Row="0" Panel.ZIndex="2" Style="{StaticResource InfoBarStyle}"
                        CornerRadius="8,8,0,0">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Name="OppNameLabel"
                                   Text="Opponent" Foreground="#CCCCCC"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <!-- Life -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock Text="❤" Foreground="#EE4444" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Name="OppLifeText" Text="40"
                                       Style="{StaticResource LifeTextStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Content="+" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Click="OppLifeUp_Click"/>
                            <Button Content="-" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Margin="2,0,0,0"
                                    Click="OppLifeDown_Click"/>
                        </StackPanel>

                        <!-- Poison -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="☠" Foreground="#AAAAAA" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Name="OppPoisonText" Text="0"
                                       Foreground="#EEEEEE" FontSize="14"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <Button Content="+" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Click="OppPoisonUp_Click"/>
                            <Button Content="-" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Margin="2,0,0,0"
                                    Click="OppPoisonDown_Click"/>
                        </StackPanel>

                        <!-- Commander damage -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="⚔" Foreground="#AAAAAA" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Name="OppCmdDmgText" Text="0"
                                       Foreground="#EEEEEE" FontSize="14"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <Button Content="+" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Click="OppCmdDmgUp_Click"/>
                            <Button Content="-" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Margin="2,0,0,0"
                                    Click="OppCmdDmgDown_Click"/>
                        </StackPanel>

                        <!-- Opp hand count -->
                        <StackPanel Grid.Column="5" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="🂠 Hand: " Foreground="#AAAAAA"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Name="OppHandCountLabel" Text="0"
                                       Foreground="#EEEEEE" FontSize="13"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Rotate table button -->
                        <Button Grid.Column="7" Name="BtnRotateTable"
                                Content="⇄ Switch Seats" Style="{StaticResource TableBtnStyle}"
                                Margin="0,0,0,0" Click="BtnRotateTable_Click"/>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 1 — OPPONENT HAND (flipped, blurred when hidden)-->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Row="1" Panel.ZIndex="2" Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="0">
                    <Grid>
                        <TextBlock Text="OPPONENT HAND" Style="{StaticResource ZoneLabelStyle}"
                                   Opacity="1.0"/>
                        <!-- Cards will be added here in Phase 4 -->
                        <Canvas Name="OppHandCanvas" SizeChanged="OppHandCanvas_SizeChanged"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </Canvas.RenderTransform>
                        </Canvas>
                        <!-- Blur overlay when hidden -->
                        <Border Name="OppHandBlur" Background="#CC1A3A1A"
                                Visibility="Collapsed">
                            <TextBlock Text="🂠  Opponent Hand Hidden  🂠"
                                       Foreground="#66FFFFFF" FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 2 — OPPONENT MANA / LAND ZONE                 -->
                <!-- ══════════════════════════════════════════════════ -->
                <Grid Grid.Row="2" Panel.ZIndex="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- CMD Zone -->
                    <Border Grid.Column="0" Style="{StaticResource ZoneBorderStyle}"
                            Margin="4,4,2,4">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CMD" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="OppCmdTaxText" Text="Tax: 0 (+0)"
                                       Foreground="#FFD700" FontSize="9"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <Button Name="BtnOppCmdReturn"
                                    Content="↩ Return" FontSize="9"
                                    Height="20" Margin="2,3,2,0"
                                    Visibility="Collapsed"
                                    Style="{StaticResource TableBtnStyle}"
                                    Click="BtnOppCmdReturn_Click"/>
                            <Canvas Name="OppCommandCanvas" Height="120"/>
                        </StackPanel>
                    </Border>

                    <!-- Battlefield -->
                    <Border Grid.Column="1" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,2,4"
                            MouseRightButtonDown="OppPlaymat_RightClick">
                        <Grid>

                            <Canvas Name="OppLandCanvas"/>
                        </Grid>
                    </Border>

                    <!-- Library -->
                    <Border Grid.Column="2" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,2,4" Cursor="Hand"
                            MouseLeftButtonDown="OppLibrary_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/Images/MTG_Back.png"
                                   Width="44" Height="62" Stretch="Fill"
                                   Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <TextBlock Text="LIBRARY" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="OppLibraryCount" Text="0"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Graveyard -->
                    <Border Grid.Column="3" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,2,4" Cursor="Hand"
                            MouseLeftButtonDown="OppGraveyard_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="💀" Foreground="#888888"
                                       FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="GRAVEYARD" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="OppGraveyardCount" Text="0"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Exile -->
                    <Border Grid.Column="4" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,4,4" Cursor="Hand"
                            MouseLeftButtonDown="OppExile_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="✦" Foreground="#888888"
                                       FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="EXILE" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="OppExileCount" Text="0"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 3 — OPPONENT BATTLEFIELD (creatures/spells)   -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Row="3" Panel.ZIndex="2" Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="0"
                        Margin="4,0"
                        MouseRightButtonDown="OppPlaymat_RightClick">
                    <Grid>

                        <Canvas Name="OppBattlefieldCanvas"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </Canvas.RenderTransform>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 4 — CENTER RAIL                               -->
                <!-- ══════════════════════════════════════════════════ -->
                <Grid Grid.Row="4" Panel.ZIndex="3">
                    <!-- Shadow above rail -->
                    <Border Background="{StaticResource ShadowTopBrush}"
                            Height="8" VerticalAlignment="Top" Margin="0,-8,0,0"/>

                    <!-- The rail itself -->
                    <Border Background="{StaticResource RailBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Turn counter -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="TURN" Foreground="#BBBBBB"
                                           FontSize="9" VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock Name="TurnCounterText" Text="1"
                                           Foreground="#FFE066" FontSize="16"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Phase tracker -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button Name="PhaseUntap"   Content="⟳ UNTAP"
                                        Style="{StaticResource ActivePhaseButtonStyle}"
                                        Click="Phase_Click" Tag="Untap"/>
                                <Button Name="PhaseUpkeep"  Content="↑ UPKEEP"
                                        Style="{StaticResource PhaseButtonStyle}"
                                        Click="Phase_Click" Tag="Upkeep"/>
                                <Button Name="PhaseDraw"    Content="🃏 DRAW"
                                        Style="{StaticResource PhaseButtonStyle}"
                                        Click="Phase_Click" Tag="Draw"/>
                                <Button Name="PhaseMain1"   Content="▶ MAIN 1"
                                        Style="{StaticResource PhaseButtonStyle}"
                                        Click="Phase_Click" Tag="Main1"/>
                                <Button Name="PhaseCombat"  Content="⚔ COMBAT"
                                        Style="{StaticResource PhaseButtonStyle}"
                                        Click="Phase_Click" Tag="Combat"/>
                                <Button Name="PhaseMain2"   Content="▶ MAIN 2"
                                        Style="{StaticResource PhaseButtonStyle}"
                                        Click="Phase_Click" Tag="Main2"/>
                                <Button Name="PhaseEnd"     Content="🏁 END"
                                        Style="{StaticResource PhaseButtonStyle}"
                                        Click="Phase_Click" Tag="End"/>
                            </StackPanel>

                            <!-- Stack toggle -->
                            <Button Grid.Column="2" Name="BtnToggleStack"
                                    Content="STACK ▼" Style="{StaticResource TableBtnStyle}"
                                    VerticalAlignment="Center" Margin="4,0"
                                    Click="BtnToggleStack_Click"/>

                            <!-- Pass turn -->
                            <Button Grid.Column="3" Name="BtnPassTurn"
                                    Content="PASS TURN ⟶"
                                    Style="{StaticResource TableBtnStyle}"
                                    VerticalAlignment="Center" Margin="4,0,8,0"
                                    Click="BtnPassTurn_Click"/>
                        </Grid>
                    </Border>

                    <!-- Shadow below rail -->
                    <Border Background="{StaticResource ShadowBottomBrush}"
                            Height="8" VerticalAlignment="Bottom" Margin="0,0,0,-8"/>
                </Grid>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 5 — YOUR BATTLEFIELD (creatures/spells)       -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Row="5" Panel.ZIndex="2" Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="0"
                        Margin="4,0"
                        MouseRightButtonDown="YourPlaymat_RightClick">
                    <Grid>

                        <Canvas Name="YourBattlefieldCanvas"/>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 6 — YOUR MANA / LAND ZONE                    -->
                <!-- ══════════════════════════════════════════════════ -->
                <Grid Grid.Row="6" Panel.ZIndex="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- CMD Zone -->
                    <Border Grid.Column="0" Style="{StaticResource ZoneBorderStyle}"
                            Margin="4,4,2,4">
                        <StackPanel VerticalAlignment="Center">
                            <Canvas Name="YourCommandCanvas" Height="120"/>
                            <TextBlock Text="CMD" Style="{StaticResource ZoneLabelStyle}"/>
                            <!-- Tax: always visible, shows cast count and additional cost -->
                            <TextBlock Name="YourCmdTaxText" Text="Tax: 0 (+0)"
                                       Foreground="#FFD700" FontSize="9"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <!-- Return button: only visible when commander not in CMD/Battlefield -->
                            <Button Name="BtnYourCmdReturn"
                                    Content="↩ Return" FontSize="9"
                                    Height="20" Margin="2,3,2,0"
                                    Visibility="Collapsed"
                                    Style="{StaticResource TableBtnStyle}"
                                    Click="BtnYourCmdReturn_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Battlefield -->
                    <Border Grid.Column="1" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,2,4"
                            MouseRightButtonDown="YourPlaymat_RightClick">
                        <Grid>

                            <Canvas Name="YourLandCanvas"/>
                        </Grid>
                    </Border>

                    <!-- Library -->
                    <Border Grid.Column="2" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,2,4" Cursor="Hand"
                            MouseLeftButtonDown="YourLibrary_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/Images/MTG_Back.png"
                                   Width="44" Height="62" Stretch="Fill"
                                   Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <TextBlock Text="LIBRARY" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="YourLibraryCount" Text="0"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Graveyard -->
                    <Border Grid.Column="3" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,2,4" Cursor="Hand"
                            MouseLeftButtonDown="YourGraveyard_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="💀" Foreground="#888888"
                                       FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="GRAVEYARD" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="YourGraveyardCount" Text="0"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Exile -->
                    <Border Grid.Column="4" Style="{StaticResource ZoneBorderStyle}"
                            Margin="2,4,4,4" Cursor="Hand"
                            MouseLeftButtonDown="YourExile_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="✦" Foreground="#888888"
                                       FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="EXILE" Style="{StaticResource ZoneLabelStyle}"/>
                            <TextBlock Name="YourExileCount" Text="0"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 7 — YOUR HAND (peek strip, click to expand) -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Row="7" Panel.ZIndex="2" Background="#AA000000"
                        BorderBrush="#44FFFFFF" BorderThickness="0,1,0,0"
                        Cursor="Hand" MouseLeftButtonDown="YourHand_Click">
                    <Grid ClipToBounds="True">
                        <!-- Peek label shown when collapsed -->
                        <StackPanel Name="HandPeekLabel" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                    Margin="0,4,0,0">
                            <TextBlock Text="▲ HAND " Foreground="White"
                                       FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Name="HandCountLabel" Text="(0)"
                                       Foreground="#CCCCCC" FontSize="10"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Canvas Name="YourHandCanvas" SizeChanged="YourHandCanvas_SizeChanged"
                                Margin="0,20,0,0"/>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- ROW 8 — YOUR INFO BAR                             -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Row="8" Panel.ZIndex="2" Background="#CC000000"
                        BorderBrush="#44FFFFFF" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,8,8">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Player name -->
                        <TextBlock Grid.Column="0" Name="YourNameLabel"
                                   Text="Player" Foreground="#CCCCCC"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <!-- Life -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock Text="❤" Foreground="#EE4444" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Name="YourLifeText" Text="40"
                                       Style="{StaticResource LifeTextStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Content="+" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Click="YourLifeUp_Click"/>
                            <Button Content="-" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Margin="2,0,0,0"
                                    Click="YourLifeDown_Click"/>
                        </StackPanel>

                        <!-- Poison -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="☠" Foreground="#AAAAAA" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Name="YourPoisonText" Text="0"
                                       Foreground="#EEEEEE" FontSize="14"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <Button Content="+" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Click="YourPoisonUp_Click"/>
                            <Button Content="-" Style="{StaticResource TableBtnStyle}"
                                    Width="20" Padding="0" Margin="2,0,0,0"
                                    Click="YourPoisonDown_Click"/>
                        </StackPanel>

                        <!-- Spacer -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Mana pool collapsed view — Phase 6 -->
                            <Border Name="ManaPoolBar" Background="#22FFFFFF"
                                    CornerRadius="3" Padding="8,2" Cursor="Hand"
                                    MouseLeftButtonDown="ManaPool_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="MANA POOL" Foreground="#88FFFFFF"
                                               FontSize="9" VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Name="ManaPoolSummary" Text="—"
                                               Foreground="#CCCCCC" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Draw Card -->
                        <Button Grid.Column="5" Content="🃏 Draw"
                                Style="{StaticResource TableBtnStyle}"
                                Margin="4,0" Click="BtnDrawCard_Click"/>

                        <!-- Mulligan -->
                        <Button Grid.Column="6" Content="↺ Mulligan"
                                Style="{StaticResource TableBtnStyle}"
                                Margin="4,0" Click="BtnMulligan_Click"/>

                        <!-- Dice -->
                        <Button Grid.Column="7" Content="🎲 Dice"
                                Style="{StaticResource TableBtnStyle}"
                                Margin="4,0" Click="BtnDice_Click"/>

                        <!-- Token -->
                        <Button Grid.Column="8" Content="🃏 Token"
                                Style="{StaticResource TableBtnStyle}"
                                Margin="4,0" Click="BtnToken_Click"/>

                        <!-- Untap All -->
                        <Button Grid.Column="9" Content="⟳ Untap All"
                                Style="{StaticResource TableBtnStyle}"
                                Margin="4,0" Click="BtnUntapAll_Click"/>

                        <!-- Settings -->
                        <Button Grid.Column="10" Content="⚙"
                                Style="{StaticResource TableBtnStyle}"
                                Width="28" Margin="4,0" FontSize="14"
                                Click="BtnTabletopSettings_Click"/>

                        <!-- Close -->
                        <Button Grid.Column="11" Content="✕"
                                Style="{StaticResource TableBtnStyle}"
                                Width="28" Margin="4,0,0,0" FontSize="14"
                                Click="BtnTabletopClose_Click"/>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- STACK OVERLAY — collapsible, centered on rail     -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Name="StackPanel" Grid.Row="4"
                        Background="#EE1A1A1A"
                        BorderBrush="#66D4AF37" BorderThickness="1"
                        CornerRadius="4" Margin="200,0,200,0"
                        Visibility="Collapsed"
                        VerticalAlignment="Stretch"
                        Panel.ZIndex="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="THE STACK"
                                   Foreground="#D4AF37" FontSize="9"
                                   FontWeight="Bold" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Canvas Grid.Row="1" Name="StackCanvas"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
