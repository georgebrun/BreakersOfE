<Window x:Class="BreakersOfE.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="900" Height="540"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">

    <Border CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24"
                              ShadowDepth="8" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <!-- Background image -->
            <Border CornerRadius="8" ClipToBounds="True">
                <Image Source="/Resources/Images/SplashScreen.jpg"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Dark gradient overlay — heavier at top and bottom for text legibility -->
            <Border CornerRadius="8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#CC000000" Offset="0.0"/>
                        <GradientStop Color="#44000000" Offset="0.35"/>
                        <GradientStop Color="#22000000" Offset="0.6"/>
                        <GradientStop Color="#EE000000" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top: Title -->
                <StackPanel Grid.Row="0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="0,36,0,0">

                    <!-- Gold rule -->
                    <Rectangle Height="2" Width="320" Margin="0,0,0,16">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent"   Offset="0.0"/>
                                <GradientStop Color="#C8A84B"       Offset="0.5"/>
                                <GradientStop Color="Transparent"   Offset="1.0"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <TextBlock Text="BREAKERS OF E"
                               FontSize="42" FontWeight="Bold"
                               FontFamily="Segoe UI"
                               Foreground="#E8D898"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="8"
                                              ShadowDepth="2" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="Magic: The Gathering Collection Manager"
                               FontSize="14" FontWeight="Normal"
                               FontFamily="Segoe UI"
                               Foreground="#C8B87A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="4"
                                              ShadowDepth="1" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Gold rule -->
                    <Rectangle Height="1" Width="240">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#C8A84B"     Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </StackPanel>

                <!-- Bottom: Progress area -->
                <Border Grid.Row="1"
                        Padding="32,16,32,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Status text -->
                        <TextBlock Grid.Row="0"
                                   Name="StatusText"
                                   Text="Initializing..."
                                   FontSize="12"
                                   Foreground="#CCCCCC"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,6">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4"
                                                  ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- Progress bar -->
                        <ProgressBar Grid.Row="1"
                                     Name="ProgressBar"
                                     Height="4"
                                     Minimum="0" Maximum="100" Value="0"
                                     Background="#33FFFFFF"
                                     BorderThickness="0">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#C8A84B" Offset="0.0"/>
                                    <GradientStop Color="#E8D898" Offset="1.0"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>

                        <!-- Version -->
                        <TextBlock Grid.Row="2"
                                   Name="VersionText"
                                   Text="Version 1.0"
                                   FontSize="10"
                                   Foreground="#88AAAAAA"
                                   HorizontalAlignment="Right"
                                   Margin="0,6,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
