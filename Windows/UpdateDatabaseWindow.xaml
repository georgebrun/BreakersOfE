<Window x:Class="BreakersOfE.Windows.UpdateDatabaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Card Database"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">

    <Window.Resources>

        <Storyboard x:Key="PulseDot1" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot1"
                Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot1"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot1"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="PulseDot2" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot2"
                Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.2"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot2"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.6"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot2"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.6"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="PulseDot3" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot3"
                Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.2"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot3"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.6"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="Dot3"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0.6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.6"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Name="WindowTitleLabel"
                   Text="Update Card Database"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Name="WindowSubtitleLabel"
                   Text="Downloads all cards, mana symbols, and set symbols from Scryfall."
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <!-- Step label + animated dots -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,4">

            <TextBlock Name="StepLabel"
                       Text="Ready"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontSize="13"
                       VerticalAlignment="Center"/>

            <StackPanel Name="DotsPanel"
                        Orientation="Horizontal"
                        Visibility="Collapsed"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center">

                <Ellipse Name="Dot1"
                         Width="8" Height="8"
                         Fill="#007ACC"
                         Margin="2,0"
                         Opacity="1.0"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Name="Dot2"
                         Width="8" Height="8"
                         Fill="#007ACC"
                         Margin="2,0"
                         Opacity="0.2"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="0.6" ScaleY="0.6"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Name="Dot3"
                         Width="8" Height="8"
                         Fill="#007ACC"
                         Margin="2,0"
                         Opacity="0.2"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="0.6" ScaleY="0.6"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

            </StackPanel>
        </StackPanel>

        <!-- Detail label -->
        <TextBlock Grid.Row="3"
                   Name="DetailLabel"
                   Text=""
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontSize="11"
                   Margin="0,0,0,10"/>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="4"
                     Name="MainProgressBar"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Height="28"
                     Background="{DynamicResource SurfaceAltBrush}"
                     Foreground="{DynamicResource AccentBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"/>

        <!-- Percentage label centered on bar -->
        <TextBlock Grid.Row="4"
                   Name="PercentLabel"
                   Text="0%"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   FontWeight="Bold"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

        <!-- Elapsed time -->
        <TextBlock Grid.Row="5"
                   Name="ElapsedLabel"
                   Text=""
                   Foreground="{DynamicResource MutedTextBrush}"
                   FontSize="11"
                   HorizontalAlignment="Right"
                   Margin="0,4,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Name="StartButton"
                    Content="Start Update"
                    Width="120" Height="32"
                    Margin="0,0,10,0"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="13"
                    Cursor="Hand"
                    Click="StartButton_Click"/>

            <Button Name="CancelButton"
                    Content="Cancel"
                    Width="90" Height="32"
                    Background="{DynamicResource SurfaceAltBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    BorderThickness="1"
                    FontSize="13"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>

        </StackPanel>
    </Grid>
</Window>
