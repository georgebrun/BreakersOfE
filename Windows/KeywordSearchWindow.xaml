<Window x:Class="BreakersOfE.Windows.KeywordSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyword Search"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="FilterHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="ColorBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" MinWidth="180"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT PANEL — FILTERS ══ -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                <StackPanel>

                    <!-- Source -->
                    <TextBlock Style="{StaticResource FilterHeader}" Text="SOURCE"/>
                    <Separator Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <RadioButton Name="RbPool" Content="Card Pool"
                                     IsChecked="True" Margin="0,0,12,0"
                                     Checked="Source_Changed"/>
                        <RadioButton Name="RbCollection" Content="Collection"
                                     Checked="Source_Changed"/>
                    </StackPanel>

                    <!-- Keywords -->
                    <TextBlock Style="{StaticResource FilterHeader}" Text="KEYWORDS"/>
                    <Separator Margin="0,0,0,4"/>

                    <!-- Keyword search box -->
                    <TextBox Name="TxtKeywordSearch"
                             Height="26" Margin="0,0,0,6"
                             VerticalContentAlignment="Center" Padding="4,0"
                             TextChanged="TxtKeywordSearch_Changed"/>

                    <!-- AND / OR toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Match:" VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontSize="11"/>
                        <RadioButton Name="RbAnd" Content="ALL (AND)"
                                     IsChecked="True" Margin="0,0,10,0"
                                     FontSize="11" Checked="Logic_Changed"/>
                        <RadioButton Name="RbOr" Content="ANY (OR)"
                                     FontSize="11" Checked="Logic_Changed"/>
                    </StackPanel>

                    <!-- Keyword checklist grouped by category -->
                    <TreeView Name="KeywordTree"
                              BorderThickness="1"
                              MaxHeight="260"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,4"/>

                    <Button Content="Clear Keywords" HorizontalAlignment="Left"
                            Padding="6,3" FontSize="10" Margin="0,2,0,0"
                            Click="BtnClearKeywords_Click"/>

                    <!-- Color Identity -->
                    <TextBlock Style="{StaticResource FilterHeader}"
                               Text="COLOR IDENTITY"/>
                    <Separator Margin="0,0,0,6"/>

                    <!-- Color buttons -->
                    <WrapPanel Margin="0,0,0,6">
                        <ToggleButton Name="BtnW" Style="{StaticResource ColorBtn}"
                                      Content="W" Background="#F9FAF1"
                                      Foreground="#444" BorderBrush="#C8B87A"
                                      Checked="Color_Changed" Unchecked="Color_Changed"/>
                        <ToggleButton Name="BtnU" Style="{StaticResource ColorBtn}"
                                      Content="U" Background="#B3CEEA"
                                      Foreground="#003" BorderBrush="#5588AA"
                                      Checked="Color_Changed" Unchecked="Color_Changed"/>
                        <ToggleButton Name="BtnB" Style="{StaticResource ColorBtn}"
                                      Content="B" Background="#3A3A3A"
                                      Foreground="#EEE" BorderBrush="#888"
                                      Checked="Color_Changed" Unchecked="Color_Changed"/>
                        <ToggleButton Name="BtnR" Style="{StaticResource ColorBtn}"
                                      Content="R" Background="#E87040"
                                      Foreground="#FFF" BorderBrush="#AA3310"
                                      Checked="Color_Changed" Unchecked="Color_Changed"/>
                        <ToggleButton Name="BtnG" Style="{StaticResource ColorBtn}"
                                      Content="G" Background="#4A8A4A"
                                      Foreground="#FFF" BorderBrush="#226622"
                                      Checked="Color_Changed" Unchecked="Color_Changed"/>
                        <ToggleButton Name="BtnC" Style="{StaticResource ColorBtn}"
                                      Content="C" Background="#999999"
                                      Foreground="#FFF" BorderBrush="#555"
                                      Checked="Color_Changed" Unchecked="Color_Changed"
                                      ToolTip="Colorless"/>
                    </WrapPanel>

                    <!-- Color mode -->
                    <StackPanel Margin="0,0,0,8">
                        <RadioButton Name="RbColorAtMost"
                                     Content="At most (Commander)"
                                     IsChecked="True" FontSize="11"
                                     Margin="0,2" Checked="Color_Changed"
                                     ToolTip="Cards whose color identity fits within the selected colors"/>
                        <RadioButton Name="RbColorIncludes"
                                     Content="Includes these colors"
                                     FontSize="11" Margin="0,2"
                                     Checked="Color_Changed"
                                     ToolTip="Cards that contain at least these colors"/>
                        <RadioButton Name="RbColorExact"
                                     Content="Exactly these colors"
                                     FontSize="11" Margin="0,2"
                                     Checked="Color_Changed"
                                     ToolTip="Cards that are exactly these colors, no more"/>
                    </StackPanel>

                    <!-- Legality -->
                    <TextBlock Style="{StaticResource FilterHeader}" Text="LEGALITY"/>
                    <Separator Margin="0,0,0,6"/>
                    <WrapPanel Margin="0,0,0,8">
                        <CheckBox Name="ChkStandard"   Content="Standard"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                        <CheckBox Name="ChkPioneer"    Content="Pioneer"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                        <CheckBox Name="ChkModern"     Content="Modern"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                        <CheckBox Name="ChkLegacy"     Content="Legacy"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                        <CheckBox Name="ChkVintage"    Content="Vintage"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                        <CheckBox Name="ChkCommander"  Content="Commander"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                        <CheckBox Name="ChkPauper"     Content="Pauper"
                                  Margin="0,2,10,2" FontSize="11"
                                  Checked="Legality_Changed"
                                  Unchecked="Legality_Changed"/>
                    </WrapPanel>

                    <!-- Reset all -->
                    <Button Content="↺ Reset All Filters"
                            HorizontalAlignment="Stretch"
                            Padding="6,4" Margin="0,4,0,0"
                            Click="BtnResetAll_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ══ SPLITTER ══ -->
        <GridSplitter Grid.Column="1" Width="4"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ══ RIGHT PANEL — RESULTS ══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Card results DataGrid -->
            <DataGrid Grid.Row="0"
                      Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionChanged="ResultsGrid_SelectionChanged"
                      MouseDoubleClick="ResultsGrid_DoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                        Binding="{Binding Name}" Width="180"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="Type"
                        Binding="{Binding TypeLine}" Width="140"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="Cost"
                        Binding="{Binding ManaCost}" Width="70"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="MV"
                        Binding="{Binding ManaValue}" Width="40"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="Set"
                        Binding="{Binding SetCode}" Width="48"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="Rarity"
                        Binding="{Binding Rarity}" Width="70"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="P/T"
                        Binding="{Binding PowerToughness}" Width="48"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="Keywords"
                        Binding="{Binding Keywords}" Width="200"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                    <DataGridTextColumn Header="Price"
                        Binding="{Binding PriceUsdDisplay}" Width="60"
                        ElementStyle="{DynamicResource CellTextStyle}"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background"
                                Value="{Binding RowBackgroundBrush}"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <!-- Bottom bar -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Count -->
                    <TextBlock Grid.Column="0" Name="ResultCountText"
                               Text="0 cards" VerticalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold"/>

                    <!-- Action buttons -->
                    <Button Grid.Column="1" Name="BtnAddToDeck"
                            Content="+ Add to Deck"
                            Padding="10,5" Margin="4,0"
                            IsEnabled="False"
                            Click="BtnAddToDeck_Click"/>
                    <Button Grid.Column="2" Name="BtnAddToCollection"
                            Content="+ Add to Collection"
                            Padding="10,5" Margin="4,0"
                            IsEnabled="False"
                            Click="BtnAddToCollection_Click"/>
                    <Button Grid.Column="3" Name="BtnAddToWantList"
                            Content="♡ Add to Want List"
                            Padding="10,5" Margin="4,0"
                            IsEnabled="False"
                            Click="BtnAddToWantList_Click"/>
                    <Button Grid.Column="4" Content="📖 Keyword Dictionary"
                            Padding="10,5" Margin="4,0,0,0"
                            Click="BtnDictionary_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
