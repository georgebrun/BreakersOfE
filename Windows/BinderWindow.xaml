<Window x:Class="BreakersOfE.Windows.BinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trade Binder — Breakers of E"
        Width="1020" Height="780"
        MinWidth="900" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#1A1008">

    <Window.Resources>
        <!-- Leather texture gradient for binder cover -->
        <LinearGradientBrush x:Key="LeatherBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2C1810" Offset="0.0"/>
            <GradientStop Color="#1A0E08" Offset="0.3"/>
            <GradientStop Color="#2C1810" Offset="0.6"/>
            <GradientStop Color="#160C06" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Ring metal gradient -->
        <LinearGradientBrush x:Key="RingBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#888888" Offset="0.0"/>
            <GradientStop Color="#DDDDDD" Offset="0.3"/>
            <GradientStop Color="#AAAAAA" Offset="0.5"/>
            <GradientStop Color="#FFFFFF" Offset="0.65"/>
            <GradientStop Color="#999999" Offset="0.8"/>
            <GradientStop Color="#555555" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Spine gradient -->
        <LinearGradientBrush x:Key="SpineBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#3D2010" Offset="0.0"/>
            <GradientStop Color="#1A0E08" Offset="0.2"/>
            <GradientStop Color="#0E0806" Offset="0.5"/>
            <GradientStop Color="#1A0E08" Offset="0.8"/>
            <GradientStop Color="#3D2010" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Page background -->
        <LinearGradientBrush x:Key="PageBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F5F0E8" Offset="0.0"/>
            <GradientStop Color="#EDE8DC" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Gold accent -->
        <SolidColorBrush x:Key="GoldBrush" Color="#C8A84B"/>

        <!-- Tab button style -->
        <Style x:Key="TabBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav button style -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#C8A84B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="22">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33C8A84B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#44C8A84B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer binder shell -->
    <Grid Background="{DynamicResource LeatherBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="44"/>
            <!-- Left spine -->
            <ColumnDefinition Width="*"/>
            <!-- Page area -->
            <ColumnDefinition Width="44"/>
            <!-- Right spine -->
        </Grid.ColumnDefinitions>

        <!-- Left spine with rings -->
        <Border Grid.Column="0" Background="{DynamicResource SpineBrush}">
            <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                <!-- Ring 1 -->
                <Ellipse Width="32" Height="32" Margin="6,20,6,0"
                         Fill="{DynamicResource RingBrush}">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4"
                                          ShadowDepth="2" Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>
                <!-- Ring 1 inner hole -->
                <Ellipse Width="18" Height="18" Margin="13,-25,13,5"
                         Fill="#0D0806"/>

                <!-- Ring 2 -->
                <Ellipse Width="32" Height="32" Margin="6,80,6,0"
                         Fill="{DynamicResource RingBrush}">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4"
                                          ShadowDepth="2" Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="18" Height="18" Margin="13,-25,13,5"
                         Fill="#0D0806"/>

                <!-- Ring 3 -->
                <Ellipse Width="32" Height="32" Margin="6,80,6,0"
                         Fill="{DynamicResource RingBrush}">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4"
                                          ShadowDepth="2" Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="18" Height="18" Margin="13,-25,13,5"
                         Fill="#0D0806"/>
            </StackPanel>
        </Border>

        <!-- Main page area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Tabs + page indicator -->
                <RowDefinition Height="*"/>
                <!-- Card page -->
                <RowDefinition Height="Auto"/>
                <!-- Navigation -->
            </Grid.RowDefinitions>

            <!-- Header / title -->
            <Border Grid.Row="0" Background="#1A0E08" Padding="0,12,0,8">
                <StackPanel>
                    <TextBlock Text="BREAKERS OF E"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#C8A84B" HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="✦  TRADE BINDER  ✦"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#E8D898" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Tabs + page indicator -->
            <Border Grid.Row="1" Background="#120A04" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Have / Want tabs -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Name="BtnTabHave" Content="📋  Have List"
                                Style="{StaticResource TabBtnStyle}"
                                Click="BtnTabHave_Click"
                                Background="#C8A84B" Foreground="#1A0E08"/>
                        <Button Name="BtnTabWant" Content="❤  Want List"
                                Style="{StaticResource TabBtnStyle}"
                                Margin="4,0,0,0"
                                Click="BtnTabWant_Click"
                                Background="#3A2810" Foreground="#C8A84B"/>
                    </StackPanel>

                    <!-- Card count -->
                    <TextBlock Grid.Column="1" Name="CardCountText"
                               Text="0 cards"
                               Foreground="#886633" FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Page indicator -->
                    <TextBlock Grid.Column="2" Name="PageIndicatorText"
                               Text="Page 1 of 1"
                               Foreground="#C8A84B" FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Page content (cream paper background) -->
            <Border Grid.Row="2" Background="{DynamicResource PageBrush}"
                    Margin="0" Padding="24,20">
                <!-- Ring holes on left edge of page -->
                <Grid>
                    <!-- Punched holes -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="-12,0,0,0" IsHitTestVisible="False">
                        <Ellipse Width="18" Height="18" Margin="0,0,0,80"
                                 Fill="#DDD8CC"
                                 Stroke="#C8C0B0" StrokeThickness="1"/>
                        <Ellipse Width="18" Height="18" Margin="0,0,0,80"
                                 Fill="#DDD8CC"
                                 Stroke="#C8C0B0" StrokeThickness="1"/>
                        <Ellipse Width="18" Height="18"
                                 Fill="#DDD8CC"
                                 Stroke="#C8C0B0" StrokeThickness="1"/>
                    </StackPanel>

                    <!-- 3x3 card grid -->
                    <UniformGrid Name="CardGrid" Columns="3" Rows="3"
                                 Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- Navigation bar -->
            <Border Grid.Row="3" Background="#1A0E08" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1" Name="BtnFirst" Content="⟨⟨"
                            Style="{StaticResource NavBtnStyle}"
                            Click="BtnFirst_Click" Margin="0,0,4,0"/>
                    <Button Grid.Column="2" Name="BtnPrev" Content="◀"
                            Style="{StaticResource NavBtnStyle}"
                            Click="BtnPrev_Click" Margin="0,0,4,0"/>
                    <Button Grid.Column="3" Name="BtnNext" Content="▶"
                            Style="{StaticResource NavBtnStyle}"
                            Click="BtnNext_Click"/>
                    <!-- Last page button would be col 4 -->
                </Grid>
            </Border>
        </Grid>

        <!-- Right spine (mirror of left, no rings) -->
        <Border Grid.Column="2" Background="{DynamicResource SpineBrush}"/>
    </Grid>
</Window>
