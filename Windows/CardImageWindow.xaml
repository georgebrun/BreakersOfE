<Window x:Class="BreakersOfE.Windows.CardImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Image"
        Width="460" Height="640"
        MinWidth="280" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Black">
    <Grid>
        <Image Name="CardImage" Stretch="Uniform"
               MouseLeftButtonDown="CardImage_Click"/>
        <TextBlock Name="CardNameText"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="0,0,0,8" FontSize="13" FontWeight="SemiBold"
                   Foreground="White"/>
    </Grid>
</Window>
