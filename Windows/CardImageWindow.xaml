<Window x:Class="BreakersOfE.Windows.CardImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Image"
        Width="460" Height="660"
        MinWidth="280" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Name="CardImage" Stretch="Uniform"
               MouseLeftButtonDown="CardImage_Click"/>

        <Button Grid.Row="1" Name="BtnFlip"
                Content="🔄 Back Face"
                Visibility="Collapsed"
                Margin="12,4,12,0" Padding="8,4"
                Background="#223355" Foreground="White"
                BorderBrush="#4466AA" FontSize="12"
                Click="BtnFlip_Click"/>

        <TextBlock Grid.Row="2" Name="CardNameText"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,8" FontSize="13" FontWeight="SemiBold"
                   Foreground="White"/>
    </Grid>
</Window>
