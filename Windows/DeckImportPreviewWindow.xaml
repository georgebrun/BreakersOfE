<Window x:Class="BreakersOfE.Windows.DeckImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Deck to Collection — Breakers of E"
        Width="820" Height="560"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Name="LblDeckName"
                   FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Select All -->
        <CheckBox Grid.Row="1"
                  Name="ChkSelectAll"
                  Content="Select All"
                  FontSize="13"
                  Margin="0,0,0,8"
                  Checked="ChkSelectAll_Changed"
                  Unchecked="ChkSelectAll_Changed"/>

        <!-- Card grid -->
        <DataGrid Grid.Row="2"
                  Name="PreviewGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="26"
                  FontSize="12"
                  BorderThickness="1"
                  BorderBrush="#CCCCCC">

            <DataGrid.Columns>
                <!-- Include checkbox -->
                <DataGridTemplateColumn Header="Include" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Include, Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ed."         Binding="{Binding SetCode}"      Width="45"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Category"    Binding="{Binding Category}"     Width="90"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Non-Foil"    Binding="{Binding NonFoilQty}"   Width="70"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Foil"        Binding="{Binding FoilQty}"      Width="50"  IsReadOnly="True"/>
                <DataGridTextColumn Header="In Collection" Binding="{Binding InCollection}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Coll. Non-Foil" Binding="{Binding CollNonFoil}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Coll. Foil"  Binding="{Binding CollFoil}"     Width="80"  IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Summary -->
        <TextBlock Grid.Row="3"
                   Name="LblSummary"
                   FontSize="12"
                   Foreground="#555555"
                   Margin="0,8,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Name="BtnImport"
                    Content="Import Selected"
                    Width="120" Height="28"
                    FontSize="13"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    Click="BtnImport_Click"/>
            <Button Name="BtnCancel"
                    Content="Cancel"
                    Width="80" Height="28"
                    FontSize="13"
                    IsCancel="True"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
