<Window x:Class="BreakersOfE.Windows.SearchForCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search for Card"
        Width="420" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Card label -->
        <TextBlock Grid.Row="0"
                   Text="Card:"
                   FontSize="13"
                   Margin="0,0,0,4"/>

        <!-- Card name combo (with history) -->
        <ComboBox Grid.Row="1"
                  Name="CardNameCombo"
                  IsEditable="True"
                  Height="28"
                  FontSize="13"
                  Margin="0,0,0,12"
                  KeyDown="CardNameCombo_KeyDown"/>

        <!-- Search in -->
        <GroupBox Grid.Row="2"
                  Header="Search in"
                  FontSize="12"
                  Padding="8,4"
                  Margin="0,0,0,12">
            <StackPanel>
                <RadioButton Name="RadioSearchPool"
                             Content="Cards (Pool)"
                             IsChecked="True"
                             FontSize="13"
                             Margin="0,2"/>
                <RadioButton Name="RadioSearchCollection"
                             Content="Collection"
                             FontSize="13"
                             Margin="0,2"/>
            </StackPanel>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Name="BtnOK"
                    Content="OK"
                    Width="75" Height="28"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    Click="BtnOK_Click"/>
            <Button Name="BtnCancel"
                    Content="Cancel"
                    Width="75" Height="28"
                    IsCancel="True"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
