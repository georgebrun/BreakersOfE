<Window x:Class="BreakersOfE.Windows.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences — Breakers of E"
        Width="520" Height="760"
        MinWidth="460" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── IDENTITY ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="IDENTITY"/>
                <Separator Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Your Name (for decks)"/>
                    <TextBox Grid.Column="1" Name="TxtAuthorName" Height="26"
                             VerticalContentAlignment="Center" Padding="4,0"/>
                </Grid>

                <!-- ── STARTUP ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="STARTUP"/>
                <Separator Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Default View on Startup"/>
                    <ComboBox Grid.Column="1" Name="CmbStartupView" Height="26">
                        <ComboBoxItem Content="Pool → Collection"  Tag="PoolToCollection"/>
                        <ComboBoxItem Content="Pool → Deck"        Tag="PoolToDeck"/>
                        <ComboBoxItem Content="Collection → Deck"  Tag="CollectionToDeck"/>
                        <ComboBoxItem Content="Pool → Tokens"      Tag="PoolToTokens"/>
                        <ComboBoxItem Content="Pool → Conspiracy"  Tag="PoolToConspiracy"/>
                        <ComboBoxItem Content="Pool → Planechase"  Tag="PoolToPlanechase"/>
                        <ComboBoxItem Content="Pool → Archenemy"   Tag="PoolToArchenemy"/>
                        <ComboBoxItem Content="Pool → Vanguard"    Tag="PoolToVanguard"/>
                        <ComboBoxItem Content="Pool → Art Series"  Tag="PoolToArtSeries"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,4" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Theme"/>
                    <ComboBox Grid.Column="1" Name="CmbTheme" Height="26">
                        <ComboBoxItem Content="System (follow Windows)" Tag="System"/>
                        <ComboBoxItem Content="Light" Tag="Light"/>
                        <ComboBoxItem Content="Dark"  Tag="Dark"/>
                    </ComboBox>
                </Grid>

                <!-- ── CARDS ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="CARDS"/>
                <Separator Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Default Condition"/>
                    <ComboBox Grid.Column="1" Name="CmbDefaultCondition" Height="26">
                        <ComboBoxItem Content="Near Mint"/>
                        <ComboBoxItem Content="Mint"/>
                        <ComboBoxItem Content="Fine"/>
                        <ComboBoxItem Content="Good"/>
                        <ComboBoxItem Content="Fair"/>
                        <ComboBoxItem Content="Poor"/>
                        <ComboBoxItem Content="Unknown"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Default Language"/>
                    <ComboBox Grid.Column="1" Name="CmbDefaultLanguage" Height="26">
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="Japanese"/>
                        <ComboBoxItem Content="Chinese Simplified"/>
                        <ComboBoxItem Content="Chinese Traditional"/>
                        <ComboBoxItem Content="German"/>
                        <ComboBoxItem Content="French"/>
                        <ComboBoxItem Content="Italian"/>
                        <ComboBoxItem Content="Spanish"/>
                        <ComboBoxItem Content="Portuguese"/>
                        <ComboBoxItem Content="Russian"/>
                        <ComboBoxItem Content="Korean"/>
                    </ComboBox>
                </Grid>

                <!-- ── PRICING ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="PRICING"/>
                <Separator Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Currency Display"/>
                    <ComboBox Grid.Column="1" Name="CmbCurrency" Height="26">
                        <ComboBoxItem Content="USD ($)"  Tag="USD"/>
                        <ComboBoxItem Content="EUR (€)"  Tag="EUR"/>
                        <ComboBoxItem Content="TIX"      Tag="TIX"/>
                    </ComboBox>
                </Grid>

                <!-- ── TABLETOP ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="TABLETOP"/>
                <Separator Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Default Starting Life"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Name="Life20" Content="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <RadioButton Name="Life30" Content="30" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <RadioButton Name="Life40" Content="40" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <RadioButton Name="LifeCustom" Content="Custom:" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBox Name="LifeCustomBox" Width="48" Height="24" Text="40"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ── FOLDERS ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="FILE LOCATIONS"/>
                <Separator Margin="0,0,0,8"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Card Images Folder"/>
                    <TextBox Grid.Column="1" Name="TxtImagesFolder" Height="26"
                             VerticalContentAlignment="Center" Padding="4,0"
                             IsReadOnly="True"/>
                    <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                            Padding="8,4" Click="BtnBrowseImages_Click"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="Decks Folder"/>
                    <TextBox Grid.Column="1" Name="TxtDecksFolder" Height="26"
                             VerticalContentAlignment="Center" Padding="4,0"
                             IsReadOnly="True"/>
                    <Button Grid.Column="2" Content="Browse..." Margin="6,0,0,0"
                            Padding="8,4" Click="BtnBrowseDecks_Click"/>
                </Grid>

                <Button Content="📂 Open App Data Folder" HorizontalAlignment="Left"
                        Margin="0,8,0,0" Padding="8,4"
                        Click="BtnOpenAppFolder_Click"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Changes take effect immediately"
                       FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="✓ Save" Width="90" Height="30"
                    FontSize="12" FontWeight="SemiBold" IsDefault="True"
                    Click="BtnSave_Click"/>
            <Button Grid.Column="3" Content="Cancel" Width="80" Height="30"
                    FontSize="12" IsCancel="True" Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
