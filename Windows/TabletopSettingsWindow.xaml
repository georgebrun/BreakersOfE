<Window x:Class="BreakersOfE.Windows.TabletopSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tabletop Settings"
        Width="420" Height="540"
        MinWidth="380" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="#1A1A2E">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#88AABB"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
            <Setter Property="Text" Value=""/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToggleCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── GAME RULES ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="GAME RULES"/>
                <Separator Background="#333355" Margin="0,0,0,8"/>

                <!-- Default starting life -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource SettingLabel}"
                               Text="Default Starting Life"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Name="Life20" Content="20" Foreground="#CCCCCC"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <RadioButton Name="Life30" Content="30" Foreground="#CCCCCC"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <RadioButton Name="Life40" Content="40" Foreground="#CCCCCC"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <RadioButton Name="LifeCustom" Content="Custom:" Foreground="#CCCCCC"
                                     Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBox Name="LifeCustomBox" Width="48" Height="24"
                                 Background="#2A2A3E" Foreground="White"
                                 BorderBrush="#555577" FontSize="12"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Text="40"/>
                    </StackPanel>
                </Grid>

                <!-- Auto-draw on pass turn -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Auto-draw on Pass Turn"/>
                        <TextBlock Foreground="#666688" FontSize="10"
                                   Text="Draw a card automatically when turn is passed"/>
                    </StackPanel>
                    <CheckBox Name="ChkAutoDraw" Grid.Column="1"
                              Style="{StaticResource ToggleCheck}" IsChecked="True"/>
                </Grid>

                <!-- Mana pool auto-empty -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Mana Pool Auto-Empties"/>
                        <TextBlock Foreground="#666688" FontSize="10"
                                   Text="Show ∅ indicator when leaving a main phase"/>
                    </StackPanel>
                    <CheckBox Name="ChkAutoEmptyMana" Grid.Column="1"
                              Style="{StaticResource ToggleCheck}" IsChecked="True"/>
                </Grid>

                <!-- Game over prompt -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Show Game Over Prompt"/>
                        <TextBlock Foreground="#666688" FontSize="10"
                                   Text="Pop up when life/poison/commander damage triggers"/>
                    </StackPanel>
                    <CheckBox Name="ChkGameOverPrompt" Grid.Column="1"
                              Style="{StaticResource ToggleCheck}" IsChecked="True"/>
                </Grid>

                <!-- ── TABLE APPEARANCE ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="TABLE APPEARANCE"/>
                <Separator Background="#333355" Margin="0,0,0,8"/>

                <!-- Table color -->
                <TextBlock Style="{StaticResource SettingLabel}" Text="Table Color" Margin="0,4,0,6"/>
                <WrapPanel Name="ColorPanel" Margin="0,0,0,8">
                    <!-- Color swatches built in code-behind -->
                </WrapPanel>

                <!-- Opponent hand blur -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Blur Opponent Hand"/>
                        <TextBlock Foreground="#666688" FontSize="10"
                                   Text="Obscure cards in the opponent's hand area"/>
                    </StackPanel>
                    <CheckBox Name="ChkBlurOppHand" Grid.Column="1"
                              Style="{StaticResource ToggleCheck}" IsChecked="True"/>
                </Grid>

                <!-- ── IMAGES ── -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="IMAGES"/>
                <Separator Background="#333355" Margin="0,0,0,8"/>

                <!-- Card sleeve -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Card Sleeve Image"/>
                        <TextBlock Name="SleevePathText" Foreground="#666688" FontSize="10"
                                   Text="Default (MTG card back)" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,4,0"
                            Padding="8,4" Background="#2A3A5A" Foreground="White"
                            BorderBrush="#4466AA" FontSize="11"
                            Click="BtnBrowseSleeve_Click"/>
                    <Button Grid.Column="2" Content="Clear" Padding="8,4"
                            Background="#3A2A2A" Foreground="White"
                            BorderBrush="#AA4444" FontSize="11"
                            Click="BtnClearSleeve_Click"/>
                </Grid>

                <!-- Your playmat -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Your Playmat"/>
                        <TextBlock Name="YourPlaymatText" Foreground="#666688" FontSize="10"
                                   Text="None" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,4,0"
                            Padding="8,4" Background="#2A3A5A" Foreground="White"
                            BorderBrush="#4466AA" FontSize="11"
                            Click="BtnBrowseYourPlaymat_Click"/>
                    <Button Grid.Column="2" Content="Clear" Padding="8,4"
                            Background="#3A2A2A" Foreground="White"
                            BorderBrush="#AA4444" FontSize="11"
                            Click="BtnClearYourPlaymat_Click"/>
                </Grid>

                <!-- Opp playmat -->
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SettingLabel}" Text="Opponent Playmat"/>
                        <TextBlock Name="OppPlaymatText" Foreground="#666688" FontSize="10"
                                   Text="None" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,4,0"
                            Padding="8,4" Background="#2A3A5A" Foreground="White"
                            BorderBrush="#4466AA" FontSize="11"
                            Click="BtnBrowseOppPlaymat_Click"/>
                    <Button Grid.Column="2" Content="Clear" Padding="8,4"
                            Background="#3A2A2A" Foreground="White"
                            BorderBrush="#AA4444" FontSize="11"
                            Click="BtnClearOppPlaymat_Click"/>
                </Grid>

                <!-- Open folders -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                    <Button Content="📂 Open Sleeves Folder" Padding="8,4" Margin="0,0,8,0"
                            Background="#222233" Foreground="#AABBCC"
                            BorderBrush="#334455" FontSize="11"
                            Click="BtnOpenSleevesFolder_Click"/>
                    <Button Content="📂 Open Playmats Folder" Padding="8,4"
                            Background="#222233" Foreground="#AABBCC"
                            BorderBrush="#334455" FontSize="11"
                            Click="BtnOpenPlaymatsFolder_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Settings apply immediately"
                       Foreground="#555577" FontSize="10" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="✓ Apply &amp; Close"
                    Width="120" Height="32" FontSize="12" FontWeight="SemiBold"
                    Background="#226622" Foreground="White" BorderBrush="#44AA44"
                    Click="BtnApply_Click"/>
            <Button Grid.Column="3" Content="✕ Cancel"
                    Width="80" Height="32" FontSize="12"
                    Background="#333333" Foreground="White" BorderBrush="#555555"
                    Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
