<Window x:Class="BreakersOfE.Windows.TokenCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Token"
        Width="420" Height="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#4444AA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- ComboBox item styling -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4444AA"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333388"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4444AA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Token Creator"
                   FontSize="16" FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>

        <!-- Form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Name="TxtName" Text="Soldier Token"/>

            <!-- Power -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Power:"/>
            <TextBox   Grid.Row="1" Grid.Column="1" Name="TxtPower" Text="1"/>

            <!-- Toughness -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Toughness:"/>
            <TextBox   Grid.Row="2" Grid.Column="1" Name="TxtToughness" Text="1"/>

            <!-- Type -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Type:"/>
            <TextBox   Grid.Row="3" Grid.Column="1" Name="TxtType"
                       Text="Token Creature — Soldier"/>

            <!-- Color checkboxes -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Colors:"
                       VerticalAlignment="Top" Margin="0,6,0,0"/>
            <WrapPanel Grid.Row="4" Grid.Column="1" Margin="0,4,0,4">
                <CheckBox Name="ChkWhite"  Content="W  White"/>
                <CheckBox Name="ChkBlue"   Content="U  Blue"/>
                <CheckBox Name="ChkBlack"  Content="B  Black"/>
                <CheckBox Name="ChkRed"    Content="R  Red"/>
                <CheckBox Name="ChkGreen"  Content="G  Green"/>
                <CheckBox Name="ChkColorless" Content="C  Colorless"/>
            </WrapPanel>

            <!-- Keywords -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Keywords:"
                       ToolTip="e.g. Flying, Haste"/>
            <TextBox   Grid.Row="5" Grid.Column="1" Name="TxtKeywords" Text=""/>

            <!-- Place in -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Place in:"/>
            <ComboBox  Grid.Row="6" Grid.Column="1" Name="CmbZone">
                <ComboBoxItem Content="Battlefield" IsSelected="True"/>
                <ComboBoxItem Content="Mana Zone"/>
            </ComboBox>

            <!-- Quantity -->
            <TextBlock Grid.Row="7" Grid.Column="0" Text="Quantity:"/>
            <Grid Grid.Row="7" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Name="TxtQty" Text="1"
                         TextAlignment="Center"/>
                <TextBlock Grid.Column="1" Margin="8,0,0,0"
                           Text="max 20" Foreground="#777777" FontSize="10"/>
            </Grid>
        </Grid>

        <!-- Presets dropdown -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Text="Quick Preset:" Foreground="#AAAAAA"
                       FontSize="11" VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <ComboBox Name="CmbPreset" Width="220" Height="28"
                      Background="#2A2A3E" Foreground="Black"
                      BorderBrush="#4444AA"
                      SelectionChanged="CmbPreset_SelectionChanged">
                <ComboBoxItem Content="— Select a preset —" IsSelected="True"/>
                <ComboBoxItem Content="1/1 White Soldier"
                              Tag="1/1 White Soldier Token|1|1|Token Creature — Soldier|W||"/>
                <ComboBoxItem Content="2/2 Green Bear"
                              Tag="Bear Token|2|2|Token Creature — Bear|G||"/>
                <ComboBoxItem Content="2/2 Black Zombie"
                              Tag="Zombie Token|2|2|Token Creature — Zombie|B||"/>
                <ComboBoxItem Content="1/1 Red Goblin"
                              Tag="Goblin Token|1|1|Token Creature — Goblin|R||"/>
                <ComboBoxItem Content="1/1 Blue Thopter (Flying)"
                              Tag="Thopter Token|1|1|Token Artifact Creature — Thopter|U|Flying|"/>
                <ComboBoxItem Content="3/3 Green Beast"
                              Tag="Beast Token|3|3|Token Creature — Beast|G||"/>
                <ComboBoxItem Content="4/4 Blue Sphinx (Flying)"
                              Tag="Sphinx Token|4|4|Token Creature — Sphinx|U|Flying|"/>
                <ComboBoxItem Content="5/5 Red Dragon (Flying)"
                              Tag="Dragon Token|5|5|Token Creature — Dragon|R|Flying|"/>
                <ComboBoxItem Content="Treasure Artifact"
                              Tag="Treasure Token|0|0|Token Artifact — Treasure|C||"/>
                <ComboBoxItem Content="Food Artifact"
                              Tag="Food Token|0|0|Token Artifact — Food|C||"/>
                <ComboBoxItem Content="Clue Artifact"
                              Tag="Clue Token|0|0|Token Artifact — Clue|C||"/>
                <ComboBoxItem Content="Blood Artifact"
                              Tag="Blood Token|0|0|Token Artifact — Blood|R||"/>
                <ComboBoxItem Content="Copy last token"
                              Tag="__COPY__"/>
            </ComboBox>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="6" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel"
                    Width="80" Background="#333344"
                    BorderBrush="#555566" IsCancel="True"
                    Click="BtnCancel_Click"/>
            <Button Grid.Column="3" Content="✓ Create Token"
                    Width="130" FontWeight="SemiBold"
                    Background="#226622" BorderBrush="#44AA44"
                    IsDefault="True" Click="BtnCreate_Click"/>
        </Grid>
    </Grid>
</Window>