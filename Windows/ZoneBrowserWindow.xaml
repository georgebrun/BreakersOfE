<Window x:Class="BreakersOfE.Windows.ZoneBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zone Browser"
        Width="860" Height="420"
        MinWidth="600" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="#1A1A2E">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Name="TitleText" Grid.Column="0"
                       Text="Graveyard" Foreground="White"
                       FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Name="BtnShuffle"
                    Content="🔀 Shuffle" Height="28" Width="90"
                    FontSize="11" Visibility="Collapsed"
                    Background="#333355" Foreground="White"
                    BorderBrush="#555599"
                    Click="BtnShuffle_Click"/>
        </Grid>

        <!-- Card scroll area -->
        <Border Grid.Row="1" Background="#11FFFFFF" CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Name="CardPanel" Orientation="Horizontal"
                            Margin="8" VerticalAlignment="Center"/>
            </ScrollViewer>
        </Border>

        <!-- Empty label -->
        <TextBlock Name="EmptyLabel" Grid.Row="1"
                   Text="This zone is empty."
                   Foreground="#666666" FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Name="CountLabel" Grid.Column="0"
                       Foreground="#AAAAAA" FontSize="11"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Close"
                    Width="80" Height="28" FontSize="11"
                    Background="#444444" Foreground="White"
                    BorderBrush="#666666"
                    Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
